# 强制 shell 脚本和 Linux 执行文件使用 LF 行尾（防止 Windows CRLF 导致 Linux 部署失败）
*.sh         text eol=lf
*.bash       text eol=lf
Dockerfile   text eol=lf
*.conf       text eol=lf

# TypeScript / JavaScript / JSON 使用 LF
*.ts         text eol=lf
*.tsx        text eol=lf
*.js         text eol=lf
*.jsx        text eol=lf
*.json       text eol=lf
*.mjs        text eol=lf
*.cjs        text eol=lf

# 配置文件
*.yaml       text eol=lf
*.yml        text eol=lf
*.toml       text eol=lf
*.env*       text eol=lf
.gitignore   text eol=lf
*.md         text eol=lf
*.sql        text eol=lf
*.prisma     text eol=lf
*.css        text eol=lf

# Windows 二进制文件（保持不变）
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.pdf        binary
*.zip        binary
*.gz         binary
*.rar        binary
