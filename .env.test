# 测试环境配置
NODE_ENV=test

# 数据库配置 (测试环境使用 PostgreSQL，与CI一致)
# CI/GitHub Actions 使用: postgresql://postgres:postgres@localhost:5432/test_db
# 本地测试时可使用: postgresql://postgres:your_local_password@localhost:5432/legal_debate_test
DATABASE_URL="postgresql://postgres:TFL5650056btg@localhost:5432/legal_debate_test?connection_limit=3&pool_timeout=10"

# Redis配置 (测试环境)
REDIS_URL="redis://localhost:6379/1"

# AI服务配置 (测试环境，使用Mock)
USE_REAL_AI=false
USE_MOCK_AI=true

# 法律数据源配置 - 测试环境使用本地数据库
LAW_ARTICLE_PROVIDER=local

# 认证配置
JWT_SECRET="test-jwt-secret-key-for-testing"
JWT_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS=10

# OAuth配置（测试环境测试值）
# 微信OAuth
WECHAT_APP_ID="test_wechat_app_id"
WECHAT_APP_SECRET="test_wechat_app_secret"
WECHAT_REDIRECT_URI="http://localhost:3000/api/auth/oauth/wechat/callback"

# QQ OAuth
QQ_APP_ID="test_qq_app_id"
QQ_APP_KEY="test_qq_app_key"
QQ_REDIRECT_URI="http://localhost:3000/api/auth/oauth/qq/callback"

# 测试日志级别
LOG_LEVEL="error"

# 邮件配置（测试占位值，用于生产配置测试）
SMTP_HOST="smtp.test.example.com"
SMTP_PORT="587"
SMTP_USER="test@example.com"
EMAIL_FROM="noreply@example.com"
ALERT_EMAIL_TO="alerts@example.com"

# 文件上传配置
MAX_FILE_SIZE="10485760"
ALLOWED_FILE_TYPES="pdf,doc,docx,txt"

# Stripe配置（测试占位值）
STRIPE_PUBLIC_KEY="pk_test_placeholder"
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_test_placeholder"

# Sentry配置（测试占位值）
SENTRY_DSN="https://test@sentry.example.com/1"
SENTRY_ENVIRONMENT="test"

# NextAuth配置
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="test-nextauth-secret-key-for-testing-purposes-32chars"
