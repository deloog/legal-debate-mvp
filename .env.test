# 测试环境配置
NODE_ENV=test

# 数据库配置 (测试环境使用 PostgreSQL，与CI一致)
# 本地测试时可使用: postgresql://postgres:password@localhost:5432/legal_debate_test
# 或使用 SQLite: file:./test.db (需要修改 schema.prisma 的 provider)
DATABASE_URL="postgresql://postgres:TFL5650056btg@localhost:5432/legal_debate_test"

# Redis配置 (测试环境)
REDIS_URL="redis://localhost:6379/1"

# AI服务配置 (测试环境，使用Mock)
USE_REAL_AI=false
USE_MOCK_AI=true

# 法律数据源配置 - 测试环境使用本地数据库
LAW_ARTICLE_PROVIDER=local

# 认证配置
JWT_SECRET="test-jwt-secret-key-for-testing"
JWT_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS=10

# OAuth配置（测试环境测试值）
# 微信OAuth
WECHAT_APP_ID="test_wechat_app_id"
WECHAT_APP_SECRET="test_wechat_app_secret"
WECHAT_REDIRECT_URI="http://localhost:3000/api/auth/oauth/wechat/callback"

# QQ OAuth
QQ_APP_ID="test_qq_app_id"
QQ_APP_KEY="test_qq_app_key"
QQ_REDIRECT_URI="http://localhost:3000/api/auth/oauth/qq/callback"

# 测试日志级别
LOG_LEVEL="error"
