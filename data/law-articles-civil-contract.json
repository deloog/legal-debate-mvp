    },
    {
      "lawName": "中华人民共和国民法典",
      "articleNumber": "第五百四十三条",
      "fullText": "当事人协商一致，可以变更合同。",
      "lawType": "LAW",
      "category": "CIVIL",
      "subCategory": "合同编",
      "tags": ["合同变更", "协商一致"],
      "keywords": ["当事人", "协商", "变更", "合同"],
