{
  "name": "legal_debate_mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src scripts prisma --cache --fix",
    "lint:check": "eslint src scripts prisma --cache",
    "lint:quick": "eslint src scripts prisma --config eslint.config.quick.mjs --cache --fix",
    "lint:quick:check": "eslint src scripts prisma --config eslint.config.quick.mjs --cache",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "precommit": "cross-env NODE_OPTIONS=--max-old-space-size=4096 lint-staged --concurrent false",
    "commitmsg": "commitlint -E HUSKY_GIT_PARAMS",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "seed:demo": "cross-env NODE_ENV=demo tsx prisma/seed-demo.ts",
    "validate:seed": "tsx scripts/validate-seed-data.ts",
    "db:reset": "npm run db:migrate -- --force && npm run db:seed",
    "clear:law-articles": "tsx scripts/cleanup/clear-seed-law-articles.ts",
    "db:backup": "tsx scripts/backup-database.ts",
    "db:restore": "tsx scripts/restore-database.ts",
    "db:schedule-backup": "tsx -e \"import('./backup-database.js').then(m => m.scheduleBackup())\"",
    "import:judiciary": "tsx scripts/import-data/import-judiciary-data.ts",
    "import:cail": "tsx scripts/import-data/import-cail-data.ts",
    "import:lawgpt": "tsx scripts/import-data/import-lawgpt-data.ts",
    "import:just-laws": "tsx scripts/import-data/convert-just-laws.ts",
    "import:all": "npm run import:judiciary && npm run import:cail && npm run import:lawgpt",
    "test:backup-recovery": "tsx scripts/test-backup-recovery.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:fast": "cross-env DATABASE_POOL_MAX=2 jest --maxWorkers=2 --forceExit",
    "test:ci": "NODE_ENV=test jest --config=config/jest.config.test.ts --coverage",
    "test:clean": "rm -f test.db && NODE_ENV=test jest --config=config/jest.config.test.ts",
    "test:e2e": "playwright test --config=config/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=config/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config=config/playwright.config.ts --debug",
    "test:e2e:ci": "NODE_ENV=test playwright test --config=config/playwright.config.ts",
    "test:e2e:codegen": "playwright codegen",
    "test:all": "jest && playwright test",
    "test:api": "jest --config=jest.config.api.js src/__tests__/api/",
    "test:api:coverage": "jest --config=jest.config.api.js src/__tests__/api/ --coverage",
    "test:integration": "jest --config=jest.config.integration.js",
    "test:integration:coverage": "jest --config=jest.config.integration.js --coverage",
    "coverage:check": "tsx scripts/check-coverage-gate.ts",
    "coverage:monitor": "tsx scripts/monitor-test-coverage.ts",
    "coverage:report": "npm run test:coverage && npm run coverage:check",
    "coverage:track": "npm run test:coverage && tsx scripts/track-coverage-history.ts",
    "code-style:check": "node scripts/check-code-style.mjs",
    "code-style:fix": "prettier --write . && eslint . --fix",
    "coverage:planning-agent": "node scripts/get-planning-agent-coverage.mjs",
    "coverage:analyze": "node scripts/analyze-existing-coverage.mjs",
    "coverage:all": "node scripts/diagnose-all-coverage.mjs",
    "coverage:agent": "jest --coverage --collectCoverageFrom=\"src/lib/agent/**/*.ts\"",
    "coverage:detailed": "jest --coverage --verbose --coverageReporters=text --coverageReporters=html"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@radix-ui/react-tabs": "^1.1.13",
    "@types/d3": "^7.4.3",
    "@types/formidable": "^3.4.6",
    "@types/ioredis": "^4.28.10",
    "@types/pdfkit": "^0.17.4",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "formidable": "^3.5.4",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.562.0",
    "mammoth": "^1.11.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "openai": "^6.14.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tesseract.js": "^7.0.0",
    "xml2js": "^0.6.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@playwright/test": "^1.57.0",
    "@prisma/client": "^5.22.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.50.0",
    "autoprefixer": "^10.4.23",
    "better-sqlite3": "^12.6.2",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-mock-extended": "^4.0.0",
    "lint-staged": "^16.2.7",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "uuid": "^13.0.0",
    "web-streams-polyfill": "^4.2.0",
    "whatwg-fetch": "^3.6.20"
  },
  "lint-staged": {
    "src/__tests__/components/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "jest --bail --findRelatedTests --passWithNoTests"
    ],
    "src/__tests__/api/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "jest --bail --findRelatedTests --passWithNoTests"
    ],
    "src/__tests__/e2e/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "avoid",
    "endOfLine": "auto",
    "quoteProps": "as-needed",
    "jsxSingleQuote": true,
    "proseWrap": "preserve"
  }
}
