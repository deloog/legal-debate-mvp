    "COMPLETION_VERIFICATION": {
      "description": "任务完成度验证清单",
      "checklist": [
        "功能实现完整：所有需求功能已实现",
        "文件位置正确：所有文件放在正确的目录下",
        "测试通过验证：相关测试全部通过",
        "代码符合规范：无ESLint/TypeScript错误",
