          "feat: 新功能",
          "fix: 修复bug",
          "docs: 文档更新",
          "style: 代码格式化",
          "refactor: 重构代码",
          "test: 测试相关",
          "chore: 构建/工具相关"
        ],
        "never_force_push": "禁止强制推送到main/master分支",
        "no_commit_without_permission": "只在用户明确要求时创建Git提交"
      }
    },

    "PERFORMANCE_RULES": {
      "description": "性能优化规范",
      "rules": {
        "database_optimization": "使用索引优化数据库查询",
