      }
    },

    "DOCUMENTATION_RULES": {
      "description": "文档编写规范",
      "rules": {
        "markdown_format": "使用Markdown格式编写文档",
        "chinese_language": "项目文档使用中文编写",
        "structure_requirements": [
          "必须有明确的标题层次（使用#, ##, ###）",
