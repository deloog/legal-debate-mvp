        "无破坏性更改：现有功能不受影响",
        "真实性验证：所有报告的文件和功能真实存在"
      ],
      "no_false_reporting": "禁止虚构完成度，必须实事求是"
    }
  },

  "enforcement_level": {
    "CRITICAL_RULES": "MUST - 必须严格遵守",
    "FILE_ORGANIZATION_RULES": "MUST - 必须严格遵守",
    "CODE_QUALITY_RULES": "SHOULD - 强烈建议遵守",
    "TESTING_RULES": "SHOULD - 强烈建议遵守",
