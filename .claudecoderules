{
  "claude_code_constraints": {
    "description": "Claude Code AI助手行为规范",
    "version": "1.0",
    "created": "2026-01-28",

    "CRITICAL_RULES": {
      "description": "违反这些规则将导致严重问题，必须严格遵守",
      "rules": {
        "no_duplicate_files": "禁止创建增强版、v2、new_等重复文件，所有改进必须在原文件上进行",
        "modify_original": "所有改进必须在原文件上进行，禁止创建增强版、备份版等重复文件",
        "no_false_reporting": "禁止虚构完成度，必须实事求是，所有测试必须真实运行并验证",
        "respect_existing_structure": "必须遵守项目现有的文件组织结构和命名规范"
      },
      "consequences": "违反这些规则将导致代码碎片化、测试不可信、项目混乱"
    },

    "FILE_ORGANIZATION_RULES": {
      "description": "文件组织规范 - 最高优先级",
      "priority": "HIGH",
      "rules": {
        "documentation_files": {
          "location": "docs/",
          "description": "所有文档文件必须放在docs/目录下",
          "examples": [
            "技术文档: docs/TECHNICAL_GUIDE.md",
            "API文档: docs/API_DOCUMENTATION.md",
            "完成总结: docs/COMPLETION_SUMMARY.md",
            "使用指南: docs/USAGE_GUIDE.md",
            "优化指南: docs/OPTIMIZATION_GUIDE.md"
          ],
          "exceptions": [
            "README.md - 放在根目录",
            "CHANGELOG.md - 放在根目录",
            "LICENSE - 放在根目录",
            "CONTRIBUTING.md - 放在根目录"
          ]
        },
        "test_files": {
          "location": "src/__tests__/",
          "description": "所有测试文件必须放在src/__tests__/目录下",
          "naming_convention": "*.test.ts, *.test.tsx, *.spec.ts",
          "structure": {
            "unit_tests": "src/__tests__/unit/",
            "integration_tests": "src/__tests__/integration/",
            "e2e_tests": "src/__tests__/e2e/"
          }
        },
        "script_files": {
          "location": "scripts/",
          "description": "所有脚本文件必须放在scripts/目录下",
          "examples": [
            "scripts/seed.ts - 数据库种子脚本",
            "scripts/migrate.ts - 数据库迁移脚本",
            "scripts/deploy.sh - 部署脚本",
            "scripts/backup.ts - 备份脚本"
          ]
        },
        "config_files": {
          "location": "根目录或config/",
          "description": "配置文件放在根目录或config/目录",
          "examples": [
            "package.json - 根目录",
            "tsconfig.json - 根目录",
            ".env - 根目录",
            "config/app.config.ts - config目录"
          ]
        },
        "component_files": {
          "location": "src/components/",
          "description": "React组件必须放在src/components/目录下",
          "structure": {
            "ui_components": "src/components/ui/",
            "feature_components": "src/components/features/",
            "layout_components": "src/components/layouts/",
            "shared_components": "src/components/shared/"
          }
        },
        "api_routes": {
          "location": "src/app/api/",
          "description": "Next.js API路由必须放在src/app/api/目录下"
        },
        "utility_functions": {
          "location": "src/lib/",
          "description": "工具函数和辅助模块必须放在src/lib/目录下",
          "examples": [
            "src/lib/db/ - 数据库相关",
            "src/lib/ai/ - AI相关",
            "src/lib/auth/ - 认证相关",
            "src/lib/utils/ - 通用工具"
          ]
        },
        "type_definitions": {
          "location": "src/types/",
          "description": "TypeScript类型定义必须放在src/types/目录下"
        }
      },
      "enforcement": "在创建任何文件之前，必须检查文件类型并放置在正确的目录下"
    },

    "CODE_QUALITY_RULES": {
      "description": "代码质量规范",
      "rules": {
        "max_lines_per_file": "单个文件最多500行，超出必须拆分为多个小文件",
