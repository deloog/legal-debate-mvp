# =============================================================================
# 法律辩论平台 - 环境变量示例文件
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# =============================================================================

# =============================================================================
# 核心配置（必填）
# =============================================================================

NODE_ENV=development

# 数据库（PostgreSQL）
DATABASE_URL="postgresql://user:password@localhost:5432/legal_debate_db"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=30000

# =============================================================================
# 认证（必填）
# =============================================================================

# JWT 密钥（生产环境必须设置，至少32位随机字符串）
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRES_IN=7d

# 生产/Staging 环境强制检查 JWT_SECRET（设为 true 可在 staging 强制检查）
REQUIRE_JWT_SECRET=false

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key

# 应用 URL（用于 CORS 等）
NEXT_PUBLIC_APP_URL=http://localhost:3000
BASE_URL=http://localhost:3000

# =============================================================================
# AI 服务（至少配置一个）
# =============================================================================

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# 智谱 AI（GLM）
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPUAI_API_KEY=your-zhipuai-api-key
ZHIPUAI_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# AI 服务提供商（deepseek / zhipu）
AI_SERVICE_PROVIDER=deepseek

# 开发环境使用 Mock AI（true 时不发起真实 API 请求）
USE_MOCK_AI=false
USE_REAL_AI=true

# =============================================================================
# 法律数据源配置
# =============================================================================

# 法律数据源提供商 (local / lawstar / pkulaw)
# - local: 使用本地数据库（推荐，已内置2万+法规，100万+法条）
# - lawstar: 法律之星API（需要额外配置）
# - pkulaw: 北大法宝API（需要额外配置）
LAW_ARTICLE_PROVIDER=local

# =============================================================================
# Redis（生产环境限流必须配置）
# =============================================================================

REDIS_URL=redis://localhost:6379
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_MODE=standalone

# Redis Sentinel（高可用模式，REDIS_MODE=sentinel 时使用）
REDIS_SENTINEL_HOSTS=
REDIS_SENTINEL_MASTER_NAME=mymaster
REDIS_SENTINEL_PASSWORD=

# Redis 持久化模式
REDIS_PERSISTENCE_MODE=rdb

# =============================================================================
# 缓存配置（可选，有默认值）
# =============================================================================

CACHE_DEFAULT_TTL=300
CACHE_DB_QUERY_TTL=60
CACHE_AI_RESPONSE_TTL=3600
CACHE_API_RESPONSE_TTL=30
CACHE_SESSION_TTL=86400
CACHE_USER_DATA_TTL=300
CACHE_CONFIG_TTL=600
CACHE_SYSTEM_TTL=3600
CACHE_TEMP_TTL=60
CACHE_MAX_SIZE=1000
CACHE_TTL=300
CACHE_KEY_PREFIX=legal_debate:
CACHE_DEFAULT_STRATEGY=memory
CACHE_MONITORING_ENABLED=false
CACHE_AUTO_REFRESH_ENABLED=false
CACHE_PRELOAD_ENABLED=false

# =============================================================================
# 支付（可选，按需配置）
# =============================================================================

# 支付宝
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_MERCHANT_ID=your-alipay-merchant-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=alipay-public-key
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payments/alipay/callback
ALIPAY_RETURN_URL=https://your-domain.com/payment/result
ALIPAY_SANDBOX=true

# 微信支付
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
WECHAT_MCH_ID=your-wechat-merchant-id
WECHAT_API_KEY_V3=your-wechat-api-key-v3
WECHAT_CERT_PATH=/path/to/apiclient_cert.pem
WECHAT_PRIVATE_KEY_PATH=/path/to/apiclient_key.pem
WECHAT_CERT_SERIAL_NO=your-cert-serial-no
WECHAT_NOTIFY_URL=https://your-domain.com/api/payments/wechat/notify
WECHAT_REFUND_NOTIFY_URL=https://your-domain.com/api/payments/wechat/refund-notify
WECHAT_REDIRECT_URI=https://your-domain.com/auth/wechat/callback


# =============================================================================
# 短信服务（可选，按需配置一个）
# =============================================================================

SMS_PROVIDER=aliyun

# 阿里云短信
ALIYUN_SMS_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-sms-sign-name
ALIYUN_SMS_TEMPLATE_CODE=SMS_000000

# 腾讯云短信
TENCENT_SMS_APP_ID=your-tencent-app-id
TENCENT_SMS_APP_KEY=your-tencent-app-key
TENCENT_SMS_SECRET_ID=your-tencent-secret-id
TENCENT_SMS_SECRET_KEY=your-tencent-secret-key
TENCENT_SMS_SIGN_NAME=your-sms-sign-name
TENCENT_SMS_TEMPLATE_CODE=your-template-code

# 告警短信（可选）
ALERT_SMS_ENABLED=false

# =============================================================================
# 邮件服务（可选）
# =============================================================================

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=法律辩论平台
EMAIL_FROM=noreply@example.com

# 告警邮件（可选）
ALERT_EMAIL_TO=admin@example.com
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook-url

# =============================================================================
# 文件上传（可选）
# =============================================================================

ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# =============================================================================
# 功能开关（可选）
# =============================================================================

ENABLE_AI_FEATURES=true
ENABLE_ENTERPRISE_ACCOUNT=false
ENABLE_LAWYER_QUALIFICATION=true

# =============================================================================
# 监控与日志（可选）
# =============================================================================

ENABLE_PERFORMANCE_MONITORING=false

# Sentry 错误监控
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# =============================================================================
# 其他配置
# =============================================================================

# bcrypt 加密强度（默认 10）
BCRYPT_SALT_ROUNDS=10

# API 超时（毫秒）
API_TIMEOUT=30000

# 允许的跨域来源（逗号分隔，留空时由代码根据 NODE_ENV 自动配置）
ALLOWED_ORIGINS=

# =============================================================================
# 阿里云OSS文件存储（生产环境）
# =============================================================================

# 是否启用OSS（本地开发设为false，生产环境设为true）
OSS_ENABLED=false

# OSS AccessKey ID
OSS_ACCESS_KEY=your-access-key-id

# OSS AccessKey Secret
OSS_SECRET_KEY=your-access-key-secret

# OSS Bucket名称
OSS_BUCKET=your-bucket-name

# OSS 地域（如 oss-cn-hangzhou、oss-cn-beijing）
OSS_REGION=oss-cn-hangzhou

# OSS 自定义域名（可选，如配置了CDN加速域名）
# OSS_ENDPOINT=https://cdn.example.com
