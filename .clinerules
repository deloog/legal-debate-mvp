{
  "ai_constraints": {
    "file_location_rules": {
      "test_files": "必须放在 src/__tests__/ 目录下",
      "documentation_files": "必须放在 docs/ 目录下",
      "script_files": "必须放在 scripts/ 目录下"
    },
    "file_modification_rules": {
      "no_duplicate_files": "禁止创建增强版、v2、new_等重复文件",
      "modify_original": "所有改进必须在原文件上进行"
    },
    "code_quality_rules": {
      "max_lines_per_file": 500,
      "follow_project_structure": "严格遵循项目现有目录结构",
      "consistent_naming": "使用一致的命名规范",
      "no_hardcoded_values": "禁止硬编码敏感配置和路径"
    },
    "code_style_requirements": {
      "description": "TypeScript代码风格要求（兼容现有Prettier配置）",
      "rules": [
        "使用单引号而非双引号",
        "使用2空格缩进",
        "避免使用默认导出，优先使用命名导出",
        "生产代码禁止使用any类型，测试文件允许",
        "类型定义使用TypeScript interface",
        "遵循现代ES6+语法规范"
      ],
      "exceptions": [
        "JSON文件必须使用双引号",
        "Next.js页面组件文件可使用默认导出",
        "配置文件遵循原有格式"
      ]
    },
    "error_handling_rules": {
      "try_catch_required": "异步操作必须有错误处理",
      "error_logging": "错误必须记录到日志系统"
    },
    "completion_verification": {
      "checklist": [
        "功能实现完整",
        "测试通过验证",
        "代码符合规范",
        "无破坏性更改",
        "文件真实存在"
      ],
      "no_false_reporting": "禁止虚构完成度，必须实事求是"
    }
  }
}
