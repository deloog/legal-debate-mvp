{
  "ai_constraints": {
    "file_location_rules": {
      "test_files": "必须放在 src/__tests__/ 目录下",
      "documentation_files": "必须放在 docs/ 目录下",
      "script_files": "必须放在 scripts/ 目录下",
      "prohibited_root_files": ["测试文件", "文档文件", "脚本文件"],
      "allowed_root_files": [".env", ".env.example", "README.md", "package.json"]
    },
    "file_modification_rules": {
      "no_duplicate_files": "禁止创建增强版、v2、new_、backup_等重复文件",
      "modify_original": "所有改进必须在原文件上进行",
      "backup_before_major_changes": "重大修改前必须创建备份文件"
    },
    "automated_verification": {
      "config_consistency_check": "修改配置文件时必须验证一致性",
      "file_existence_verification": "报告创建的文件必须实际存在",
      "dependency_check": "添加依赖时必须检查兼容性",
      "delivery_verification": "交付物必须经过实际验证"
    },
    "decision_documentation": {
      "adr_required_for": ["架构变更", "技术选型", "重大重构"],
      "record_major_decisions": "重大决策必须记录原因和影响",
      "change_log_required": "重要修改必须更新变更日志"
    },
    "completion_verification": {
      "self_check_required": true,
      "checklist": [
        "功能实现完整",
        "测试通过验证",
        "代码符合规范",
        "文档同步更新",
        "无破坏性更改",
        "文件真实存在",
        "配置一致性"
      ],
      "no_false_reporting": "禁止以时间紧为借口虚构完成度，必须实事求是",
      "delivery_validation": "声称的交付物必须实际存在并可验证"
    },
    "file_protection": {
      "no_overwrite_with_placeholders": "禁止用占位符覆盖已有文件内容",
      "preserve_functionality": "修改文件时必须保留原有功能",
      "verify_before_overwrite": "覆盖文件前必须验证内容完整性"
    },
    "development_process": {
      "pre_commit_checks": ["代码规范", "测试通过", "文档更新"],
      "impact_analysis_required": "重大修改前必须进行影响分析",
      "incremental_development": "采用增量开发，避免大规模重写",
      "test_first": "重要功能应先编写测试"
    },
    "code_quality_rules": {
      "max_lines_per_file": 200,
      "split_large_files": "超过200行的功能应拆分为多个模块",
      "follow_project_structure": "严格遵循项目现有目录结构",
      "consistent_naming": "使用一致的命名规范",
      "no_hardcoded_values": "禁止硬编码敏感配置和路径"
    },
    "code_style_requirements": {
      "description": "TypeScript代码风格要求（兼容现有Prettier配置）",
      "rules": [
        "使用单引号而非双引号（字符串、JSX属性等）",
        "使用2空格缩进而非制表符或4空格",
        "避免使用默认导出（default export），优先使用命名导出",
        "函数和类使用明确的命名而非匿名函数",
        "类型定义使用TypeScript而非JSDoc注释",
        "遵循现代ES6+语法规范"
      ],
      "exceptions": [
        "JSON文件必须使用双引号",
        "Next.js页面组件文件（app/目录）可使用默认导出",
        "配置文件（如package.json）遵循原有格式"
      ],
      "compatibility_note": "当前使用Prettier进行代码格式化，配置位于config/.prettierrc"
    }
  }
}
