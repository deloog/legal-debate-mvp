{
  "ai_constraints": {
    "CRITICAL_RULES": {
      "description": "违反这些规则将导致严重问题，必须严格遵守",
      "rules": {
        "no_duplicate_files": "禁止创建增强版、v2、new_等重复文件，所有改进必须在原文件上进行",
        "modify_original": "所有改进必须在原文件上进行，禁止创建增强版、备份版等重复文件",
        "no_false_reporting": "禁止虚构完成度，必须实事求是，所有测试必须真实运行并验证"
      },
      "consequences": "违反这些规则将导致代码碎片化、测试不可信、项目混乱"
    },
    
    "HIGH_PRIORITY_RULES": {
      "description": "重要规则，应优先遵守，违反将影响代码质量和维护性",
      "rules": {
        "max_lines_per_file": "单个文件最多500行，超出必须拆分为多个小文件",
        "file_location_rules": {
          "test_files": "必须放在 src/__tests__/ 目录下",
          "documentation_files": "必须放在 docs/ 目录下",
          "script_files": "必须放在 scripts/ 目录下"
        },
        "no_hardcoded_values": "禁止硬编码敏感配置（如数据库密码、API密钥）和路径，必须使用环境变量",
        "no_any_type": "生产代码禁止使用any类型，测试文件允许但不推荐",
        "opportunistic_cleanup": "每次修改某个文件时，必须顺带修复该文件中已存在的以下问题：(1) any类型 → 替换为具体类型或unknown；(2) console.log/warn/error → 替换为 import { logger } from '@/lib/logger' 的对应方法；(3) 非必要的eslint-disable注释 → 删除并修复根本原因。目的：防止技术债务永远积压，不等专项重构",
        "no_special_chars_in_paths": "禁止在文件路径中使用方括号[]等特殊字符。方括号在glob模式中是特殊字符，会导致VSCode、TypeScript、Jest出现内存溢出问题。Next.js动态路由（如 [id]）虽然框架支持，但必须确保在tsconfig.json和jest.config.js中正确排除这些路径。"
      },
      "consequences": "违反这些规则将导致代码可读性降低、维护困难、安全风险"
    },
    
    "STANDARD_RULES": {
      "description": "标准代码规范，尽量遵守，遵循现代TypeScript最佳实践",
      "rules": {
        "code_style_requirements": {
          "description": "TypeScript代码风格要求（兼容现有Prettier配置）",
          "rules": [
            "使用单引号而非双引号",
            "使用2空格缩进",
            "避免使用默认导出，优先使用命名导出（Next.js页面组件除外）",
            "生产代码禁止使用any类型，测试文件允许",
            "类型定义使用TypeScript interface",
            "遵循现代ES6+语法规范"
          ],
          "exceptions": [
            "JSON文件必须使用双引号",
            "Next.js页面组件文件可使用默认导出",
            "配置文件遵循原有格式"
          ]
        },
        "error_handling_rules": {
          "try_catch_required": "异步操作必须有错误处理",
          "error_logging": "错误必须记录到日志系统，不能静默失败"
        },
        "testing_rules": {
          "coverage_required": "测试覆盖率目标 > 80%",
          "unit_test_required": "核心功能必须有单元测试",
          "test_file_location": "测试文件必须放在 src/__tests__/ 目录",
          "e2e_ai_config": "E2E测试默认使用Mock AI服务（USE_REAL_AI=false）。启用真实AI服务需设置 USE_REAL_AI=true 环境变量。真实AI测试会产生API调用费用和延迟，仅在准确性测试或需要验证真实API行为时使用。开发/测试阶段建议使用Mock模式以提升速度并节省成本。"
        }
      },
      "consequences": "违反这些规则将导致代码风格不一致、测试不完整、错误难以追踪"
    },
    
    "performance_optimization": {
      "description": "性能优化建议，非强制但推荐遵守",
      "rules": {
        "avoid_large_files": "避免单个文件过大，超过200行建议拆分（硬性限制500行）",
        "use_memoization": "重复计算使用缓存或记忆化优化",
        "lazy_loading": "前端组件使用懒加载优化首屏加载",
        "database_indexing": "数据库查询需要时创建索引"
      }
    },
    
    "completion_verification": {
      "description": "任务完成度验证清单，AI助手报告任务完成时必须满足",
      "checklist": [
        "功能实现完整：所有需求功能已实现",
        "测试通过验证：相关测试全部通过，测试覆盖率达标",
        "代码符合规范：符合.clinerules规范，无ESLint/TypeScript错误",
        "无破坏性更改：现有功能不受影响，向后兼容",
        "文件真实存在：所有创建的文件确实存在且可访问"
      ],
      "no_false_reporting": "禁止虚构完成度，必须实事求是，提供真实的测试结果和文件路径"
    }
  }
}
