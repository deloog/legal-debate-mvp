er' || savedMode === 'enterprise') {\n> 213 |       setModeState(savedMode);\n      |       ^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  214 |     }\n  215 |   }, []);\n  216 |","'ClaimDependencyInfo' is defined but never used.","@typescript-eslint/no-require-imports","A `require()` style import is forbidden.","CallExpression","noRequireImports",["10073"],["10074","10075"],"'TimelineEvent' is defined but never used.",["10076"],"'DisputeFocusItem' is defined but never used.",["10077"],["10078"],"'logger' is defined but never used.","'DEFAULT_OPTIMIZER_CONFIG' is defined but never used.","'OptimizationStage' is defined but never used.","'content' is defined but never used.","'parties' is defined but never used.","'uncertainItems' is defined but never used.","'confirmations' is defined but never used.","'ExtractedData' is defined but never used.",["10079","10080"],["10081","10082"],["10083","10084"],["10085","10086"],["10087","10088"],"'_caseInfo' is defined but never used.",["10089"],"'_lawArticles' is defined but never used.",["10090"],"'_article' is defined but never used.",["10091"],"'laws' is defined but never used.",["10092"],["10093","10094"],["10095"],["10096","10097"],["10098","10099"],["10100","10101"],["10102","10103"],["10104","10105"],["10106","10107"],["10108","10109"],["10110","10111"],["10112","10113"],["10114","10115"],["10116","10117"],["10118","10119"],["10120","10121"],["10122","10123"],["10124","10125"],["10126","10127"],["10128","10129"],"'source' is defined but never used.",["10130"],["10131","10132"],["10133","10134"],["10135","10136"],["10137","10138"],["10139","10140"],["10141","10142"],["10143","10144"],["10145","10146"],["10147","10148"],["10149","10150"],["10151","10152"],["10153","10154"],["10155","10156"],["10157","10158"],["10159","10160"],["10161","10162"],["10163","10164"],["10165","10166"],["10167","10168"],["10169","10170"],["10171","10172"],["10173","10174"],"'LoadBalancingStrategy' is defined but never used.",