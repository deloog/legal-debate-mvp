model EnterpriseRiskProfile {
  id                     String            @id @default(cuid())
  enterpriseId           String
  industryType           String
  assessedAt             DateTime          @default(now())
  legalRiskScore         Float             @default(0)
  contractRiskScore      Float             @default(0)
  complianceRiskScore    Float             @default(0)
  overallRiskScore       Float             @default(0)
  riskLevel              String
  riskFactors            Json
  topRisks               Json[]
  recommendations        Json[]
  totalContractsAnalyzed Int               @default(0)
  highRiskContracts      Int               @default(0)
  mediumRiskContracts    Int               @default(0)
  lowRiskContracts       Int               @default(0)
