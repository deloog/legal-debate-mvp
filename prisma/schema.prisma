}

model KnowledgeGraphQualityScore {
  id                String             @id @default(cuid())
  relationId        String             @unique
  aiConfidence      Float?
  verificationCount Int                @default(0)
  positiveFeedback  Int                @default(0)
  negativeFeedback  Int                @default(0)
  qualityScore      Float
  qualityLevel      String
  lastCalculatedAt  DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  relation          LawArticleRelation @relation(fields: [relationId], references: [id], onDelete: Cascade)

  @@index([relationId])
  @@index([qualityScore])
  @@index([qualityLevel])
  @@map("knowledge_graph_quality_scores")
}

model KnowledgeGraphExpert {
  id                String               @id @default(cuid())
  userId            String               @unique
  expertiseAreas    String[]
  expertLevel       ExpertLevel          @default(JUNIOR)
  certifiedBy       String?
  certifiedAt       DateTime?
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  addedRelations    LawArticleRelation[] @relation("ExpertAddedRelations")
  verifiedRelations LawArticleRelation[] @relation("ExpertVerifiedRelations")
}

model KnowledgeGraphSnapshot {
  id                String   @id @default(cuid())
  snapshotDate      DateTime @unique
  version           String
  versionLabel      String
  totalArticles     Int      @default(0)
  totalRelations    Int      @default(0)
  verifiedRelations Int      @default(0)
  pendingRelations  Int      @default(0)
  averageConfidence Float    @default(0)
  snapshotData      Json?
  changes           Json?
  status            String   @default("COMPLETED")
  description       String?
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([snapshotDate])
  @@index([version])
  @@index([status])
  @@map("knowledge_graph_snapshots")
}

model Reviewer {
  id                   String           @id @default(cuid())
  userId               String           @unique
  reviewerLevel        ReviewerLevel    @default(JUNIOR)
  specialty            String[]
  totalReviews         Int              @default(0)
  approvedCount        Int              @default(0)
  rejectedCount        Int              @default(0)
  revisionCount        Int              @default(0)
  averageReviewTime    Float?
  accuracyRate         Float?
  maxConcurrentReviews Int              @default(10)
  isActive             Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  reviews              AIOutputReview[]
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reviewerLevel])
  @@index([isActive])
  @@map("reviewers")
}

model AIOutputReview {
  id              String               @id @default(cuid())
  outputType      AIOutputType
  outputId        String?
  content         String
  aiProvider      String?
  aiModel         String?
  caseId          String?
  documentId      String?
  consultationId  String?
  status          AIOutputReviewStatus @default(PENDING)
  priority        Int                  @default(0)
  reviewerId      String?
  verifiedBy      String?
  verifiedAt      DateTime?
  verifiedComment String?
  sourceValidated Boolean              @default(false)
  sourceUrl       String?
  validationError String?
  confidenceScore Float?
  reviewHistory   Json?
  reviewDuration  Int?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  reviewer        Reviewer?            @relation(fields: [reviewerId], references: [id])
  verifiedByUser  User?                @relation("VerifiedByUser", fields: [verifiedBy], references: [id])

  @@index([outputType])
  @@index([outputId])
  @@index([status])
  @@index([priority])
  @@index([reviewerId])
  @@index([caseId])
  @@index([createdAt])
  @@index([verifiedBy])
  @@map("ai_output_reviews")
}

model ContractPerformance {
  id                 String          @id @default(cuid())
  contractId         String
  milestone          String
  milestoneDate      DateTime
  milestoneStatus    MilestoneStatus @default(PENDING)
  description        String?
  milestoneType      String?
  actualDate         DateTime?
  actualAmount       Decimal?        @db.Decimal(15, 2)
  variance           Decimal?        @db.Decimal(15, 2)
  varianceReason     String?
  isAnomalous        Boolean         @default(false)
  anomalyType        AnomalyType?
  anomalyDescription String?
  recommendedAction  String?
  reminderEnabled    Boolean         @default(true)
  reminderDays       Int[]           @default([7, 3, 1])
  reminderSent       Boolean         @default(false)
  reminderCount      Int             @default(0)
  lastReminderAt     DateTime?
  responsibleParty   String?
  responsibleRole    String?
  caseId             String?
  notes              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  contract           Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([milestoneDate])
  @@index([milestoneStatus])
  @@index([isAnomalous])
  @@index([caseId])
  @@index([reminderSent])
  @@map("contract_performances")
}

model ReminderConfig {
  id                 String             @id @default(cuid())
  enterpriseId       String?
  userId             String?
  reminderType       String
  enabled            Boolean            @default(true)
  channels           String[]           @default(["IN_APP"])
  advanceDays        Int[]              @default([7, 3, 1])
  timeOfDay          String?
  isRecurring        Boolean            @default(false)
  recurringPattern   String?
  isActive           Boolean            @default(true)
  totalRemindersSent Int                @default(0)
  lastSentAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  enterprise         EnterpriseAccount? @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  user               User?              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([enterpriseId, reminderType])
  @@unique([userId, reminderType])
  @@index([enterpriseId])
  @@index([userId])
  @@index([reminderType])
  @@index([enabled])
  @@map("reminder_configs")
}

model BusinessSystemIntegration {
  id                 String               @id @default(cuid())
  enterpriseId       String
  systemType         BusinessSystemType
  systemName         String
  systemUrl          String
  authType           IntegrationAuthType
  authToken          String?
  authTokenEncrypted Boolean              @default(false)
  apiKey             String?
  apiKeyEncrypted    Boolean              @default(false)
  refreshToken       String?
  tokenExpiresAt     DateTime?
  syncConfig         Json
  syncEnabled        Boolean              @default(true)
  syncInterval       Int                  @default(3600)
  webhookUrl         String?
  webhookSecret      String?
  webhookEnabled     Boolean              @default(false)
  webhookEvents      String[]             @default([])
  status             IntegrationStatus    @default(PENDING)
  lastSyncAt         DateTime?
  lastSyncStatus     String?
  lastSyncError      String?
  connectionTestedAt DateTime?
  connectionStatus   String?
  totalSyncs         Int                  @default(0)
  successSyncs       Int                  @default(0)
  failedSyncs        Int                  @default(0)
  description        String?
  metadata           Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  enterprise         EnterpriseAccount    @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  syncLogs           IntegrationSyncLog[]

  @@index([enterpriseId])
  @@index([systemType])
  @@index([status])
  @@index([lastSyncAt])
  @@map("business_system_integrations")
}

model IntegrationSyncLog {
  id               String                    @id @default(cuid())
  integrationId    String
  syncType         String
  eventType        IntegrationSyncEvent?
  direction        String
  status           String
  startedAt        DateTime                  @default(now())
  completedAt      DateTime?
  recordsProcessed Int                       @default(0)
  recordsCreated   Int                       @default(0)
  recordsUpdated   Int                       @default(0)
  recordsDeleted   Int                       @default(0)
  errorMessage     String?
  errorDetails     Json?
  requestData      Json?
  responseData     Json?
  duration         Int?
  createdAt        DateTime                  @default(now())
  integration      BusinessSystemIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@index([syncType])
  @@index([status])
  @@index([startedAt])
  @@index([eventType])
  @@map("integration_sync_logs")
}

model ComplianceRule {
  id                String                      @id @default(cuid())
  ruleCode          String                      @unique
  ruleName          String
  ruleType          ComplianceRuleType
  source            ComplianceRuleSource
  sourceUrl         String?
  description       String?
  effectiveDate     DateTime
  expiryDate        DateTime?
  businessProcesses String[]
  controlPoints     String[]
  checklistItems    Json[]
  status            String                      @default("active")
  version           String                      @default("1.0")
  lastUpdated       DateTime                    @default(now())
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  sourceRelations   ComplianceRuleRelation[]    @relation("SourceRuleRelations")
  targetRelations   ComplianceRuleRelation[]    @relation("TargetRuleRelations")
  complianceChecks  EnterpriseComplianceCheck[]

  @@index([ruleType])
  @@index([source])
  @@index([status])
  @@index([effectiveDate])
  @@map("compliance_rules")
}

model ComplianceRuleRelation {
  id           String                     @id @default(cuid())
  sourceRuleId String
  targetRuleId String
  relationType ComplianceRuleRelationType
  strength     Float                      @default(1.0)
  confidence   Float                      @default(1.0)
  description  String?
  status       String                     @default("pending")
  verifiedBy   String?
  verifiedAt   DateTime?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  sourceRule   ComplianceRule             @relation("SourceRuleRelations", fields: [sourceRuleId], references: [id], onDelete: Cascade)
  targetRule   ComplianceRule             @relation("TargetRuleRelations", fields: [targetRuleId], references: [id], onDelete: Cascade)

  @@unique([sourceRuleId, targetRuleId, relationType])
  @@index([sourceRuleId])
  @@index([targetRuleId])
  @@index([relationType])
  @@index([status])
  @@map("compliance_rule_relations")
}

model EnterpriseComplianceCheck {
  id                  String                @id @default(cuid())
  enterpriseId        String
  ruleId              String
  checkDate           DateTime
  checkResult         ComplianceCheckResult
  checklistResults    Json[]
  nonCompliances      Json[]
  remediationPlan     String?
  remediationDeadline DateTime?
  remediationStatus   String                @default("pending")
  reviewerId          String?
  reviewerNotes       String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  enterprise          EnterpriseAccount     @relation(fields: [enterpriseId], references: [id])
  rule                ComplianceRule        @relation(fields: [ruleId], references: [id])

  @@index([enterpriseId])
  @@index([ruleId])
  @@index([checkResult])
  @@index([checkDate])
  @@index([remediationStatus])
  @@map("enterprise_compliance_checks")
}

model ExecutiveReport {
  id              String              @id @default(cuid())
  enterpriseId    String
  reportType      ExecutiveReportType
  title           String
  summary         String?
  metrics         Json
  charts          Json[]
  insights        String[]
  generatedBy     String              @default("ai")
  generatedAt     DateTime            @default(now())
  periodStart     DateTime
  periodEnd       DateTime
  recipients      String[]
  viewedCount     Int                 @default(0)
  downloadedCount Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  enterprise      EnterpriseAccount   @relation(fields: [enterpriseId], references: [id])

  @@index([enterpriseId])
  @@index([reportType])
  @@index([generatedAt])
  @@map("executive_reports")
}

model IndustryRiskFeature {
  id                     String   @id @default(cuid())
  industryCode           String   @unique
  industryName           String
  industryCategory       String
  riskCategories         String[]
  commonRisks            Json[]
  riskIndicators         Json[]
  riskThresholds         Json
  regulatoryRequirements Json?
  isActive               Boolean  @default(true)
  version                String   @default("1.0")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([industryCategory])
  @@index([isActive])
  @@map("industry_risk_features")
}

