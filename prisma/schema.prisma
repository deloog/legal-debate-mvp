generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String     @id @default(cuid())
  email                String     @unique
  username             String?
  name                 String?
  role                 UserRole   @default(USER)
  permissions          Json?
  organizationId       String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  deletedAt            DateTime?
  address              String?
  avatar               String?
  bio                  String?
  emailVerified        DateTime?
  lastLoginAt          DateTime?
  loginCount           Int        @default(0)
  passwordResetExpires DateTime?
  passwordResetToken   String?
  phone                String?
  preferences          Json?
  status               UserStatus @default(ACTIVE)
  accounts             Account[]
  cases                Case[]
  debates              Debate[]
  documents            Document[]
  sessions             Session[]

  @@index([email])
  @@index([username])
  @@index([organizationId])
  @@index([status])
  @@index([lastLoginAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Case {
  id              String           @id @default(cuid())
  userId          String
  title           String
  description     String
  type            CaseType
  status          CaseStatus       @default(DRAFT)
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  amount          Decimal?
  caseNumber      String?
  cause           String?
  court           String?
  defendantName   String?
  plaintiffName   String?
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  debates         Debate[]
  documents       Document[]
  legalReferences LegalReference[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([plaintiffName])
  @@index([defendantName])
  @@index([cause])
  @@map("cases")
}

model Document {
  id             String         @id @default(cuid())
  caseId         String
  userId         String
  filename       String
  filePath       String
  fileType       String
  fileSize       Int
  mimeType       String
  extractedData  Json?
  analysisStatus AnalysisStatus @default(PENDING)
  analysisResult Json?
  analysisError  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  case           Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([userId])
  @@index([analysisStatus])
  @@map("documents")
}

model Debate {
  id           String        @id @default(cuid())
  caseId       String
  userId       String
  title        String
  status       DebateStatus  @default(DRAFT)
  currentRound Int           @default(0)
  debateConfig Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  rounds       DebateRound[]
  case         Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("debates")
}

model DebateRound {
  id          String      @id @default(cuid())
  debateId    String
  roundNumber Int
  status      RoundStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  arguments   Argument[]
  debate      Debate      @relation(fields: [debateId], references: [id], onDelete: Cascade)

  @@unique([debateId, roundNumber])
  @@index([debateId])
  @@index([status])
  @@map("debate_rounds")
}

model Argument {
  id             String       @id @default(cuid())
  roundId        String
  side           ArgumentSide
  content        String
  type           ArgumentType @default(MAIN_POINT)
  aiProvider     String?
  generationTime Int?
  confidence     Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  round          DebateRound  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId])
  @@index([side])
  @@map("arguments")
}

model LegalReference {
  id                  String               @id @default(cuid())
  caseId              String?
  source              String
  content             String
  lawType             String?
  articleNumber       String?
  retrievalQuery      String?
  relevanceScore      Float?
  metadata            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  amendmentHistory    Json?
  analysisResult      Json?
  analyzedAt          DateTime?
  analyzedBy          String?
  applicabilityReason String?
  applicabilityScore  Float?
  cacheExpiry         DateTime?
  cacheSource         String?
  category            String?
  effectiveDate       DateTime?
  expiryDate          DateTime?
  hitCount            Int                  @default(0)
  lastAccessed        DateTime?
  status              LegalReferenceStatus @default(VALID)
  tags                String[]
  version             String?
  case                Case?                @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([lawType])
  @@index([relevanceScore])
  @@index([applicabilityScore])
  @@index([status])
  @@index([cacheExpiry])
  @@index([hitCount])
  @@index([category])
  @@map("legal_references")
}

model LawArticle {
  id                String              @id @default(cuid())

  // === 基础信息 ===
  lawName           String
  articleNumber     String
  fullText          String              @db.Text

  // === 分类系统 ===
  lawType           LawType
  category          LawCategory
  subCategory       String?
  tags              String[]
  keywords          String[]

  // === 版本管理 ===
  version           String              @default("1.0")
  effectiveDate     DateTime
  expiryDate        DateTime?
  status            LawStatus           @default(VALID)
  amendmentHistory  Json?

  // === 层级关系 ===
  parentId          String?
  chapterNumber     String?
  sectionNumber     String?
  level             Int                 @default(0)

  // === 元数据 ===
  issuingAuthority  String
  jurisdiction      String?
  relatedArticles   String[]
  legalBasis        String?

  // === 检索和统计 ===
  searchableText    String              @db.Text
  viewCount         Int                 @default(0)
  referenceCount    Int                 @default(0)

  // === 时间戳 ===
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // === 关联关系 ===
  parent            LawArticle?         @relation("ArticleHierarchy", fields: [parentId], references: [id])
  children          LawArticle[]        @relation("ArticleHierarchy")

  @@unique([lawName, articleNumber])
  @@index([lawType])
  @@index([category])
  @@index([status])
  @@index([effectiveDate])
  @@index([lawName])
  @@index([articleNumber])
  @@index([tags])
  @@index([viewCount])
  @@index([referenceCount])
  @@map("law_articles")
}

model AIInteraction {
  id         String   @id @default(cuid())
  type       String
  provider   String
  model      String?
  request    Json
  response   Json?
  tokensUsed Int?
  duration   Int?
  cost       Float?
  success    Boolean
  error      String?
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([provider])
  @@index([success])
  @@index([createdAt])
  @@map("ai_interactions")
}

enum UserRole {
  USER
  LAWYER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  INACTIVE
}

enum CaseType {
  CIVIL
  CRIMINAL
  ADMINISTRATIVE
  COMMERCIAL
  LABOR
  INTELLECTUAL
  OTHER
}

enum CaseStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
  DELETED
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DebateStatus {
  DRAFT
  IN_PROGRESS
  PAUSED
  COMPLETED
  ARCHIVED
}

enum RoundStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum ArgumentSide {
  PLAINTIFF
  DEFENDANT
  NEUTRAL
}

enum ArgumentType {
  MAIN_POINT
  SUPPORTING
  REBUTTAL
  EVIDENCE
  LEGAL_BASIS
  CONCLUSION
}

enum LegalReferenceStatus {
  VALID
  EXPIRED
  AMENDED
  REPEALED
  DRAFT
}

enum LawType {
  CONSTITUTION
  LAW
  ADMINISTRATIVE_REGULATION
  LOCAL_REGULATION
  JUDICIAL_INTERPRETATION
  DEPARTMENTAL_RULE
  OTHER
}

enum LawCategory {
  CIVIL
  CRIMINAL
  ADMINISTRATIVE
  COMMERCIAL
  ECONOMIC
  LABOR
  INTELLECTUAL_PROPERTY
  PROCEDURE
  OTHER
}

enum LawStatus {
  DRAFT
  VALID
  AMENDED
  REPEALED
  EXPIRED
}
