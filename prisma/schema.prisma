model Order {
  id               String          @id @default(cuid())
  orderNo          String          @unique
  userId           String
  membershipTierId String
  paymentMethod    PaymentMethod   @default(WECHAT)
  status           OrderStatus     @default(PENDING)
  amount           Decimal         @db.Decimal(10, 2)
  currency         String          @default("CNY")
  description      String
  metadata         Json?
  expiredAt        DateTime
  paidAt           DateTime?
  failedReason     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  invoices         Invoice[]
  membershipTier   MembershipTier  @relation(fields: [membershipTierId], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentRecords   PaymentRecord[]
  refundRecords    RefundRecord[]

  @@index([userId])
  @@index([membershipTierId])
  @@index([paymentMethod])
  @@index([status])
  @@index([orderNo])
  @@index([expiredAt])
  @@index([createdAt])
  @@index([userId, status, expiredAt])
  @@map("orders")
}

model PaymentRecord {
  id                String         @id @default(cuid())
  orderId           String
  userId            String
  paymentMethod     PaymentMethod  @default(WECHAT)
  status            PaymentStatus  @default(PENDING)
  amount            Decimal        @db.Decimal(10, 2)
  currency          String         @default("CNY")
  transactionId     String?
  thirdPartyOrderNo String?
  errorCode         String?
  errorMessage      String?
  metadata          Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refundRecords     RefundRecord[]

  @@index([orderId])
  @@index([userId])
  @@index([paymentMethod])
  @@index([status])
  @@index([transactionId])
  @@index([thirdPartyOrderNo])
  @@index([createdAt])
  @@map("payment_records")
}

model RefundRecord {
  id                 String        @id @default(cuid())
  orderId            String
  paymentRecordId    String
  userId             String
  paymentMethod      PaymentMethod @default(WECHAT)
  status             RefundStatus  @default(PENDING)
  reason             RefundReason
  amount             Decimal       @db.Decimal(10, 2)
  refundAmount       Decimal       @db.Decimal(10, 2)
  currency           String        @default("CNY")
  transactionId      String?
  thirdPartyRefundNo String?
  rejectedReason     String?
  metadata           Json?
  appliedAt          DateTime      @default(now())
  processedAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  order              Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentRecord      PaymentRecord @relation(fields: [paymentRecordId], references: [id], onDelete: Cascade)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([paymentRecordId])
  @@index([userId])
  @@index([paymentMethod])
  @@index([status])
  @@index([reason])
  @@index([appliedAt])
  @@index([createdAt])
  @@map("refund_records")
}

model Invoice {
  id        String        @id @default(cuid())
  orderId   String
  userId    String
  type      InvoiceType   @default(PERSONAL)
  status    InvoiceStatus @default(PENDING)
  amount    Decimal       @db.Decimal(10, 2)
  currency  String        @default("CNY")
  title     String?
  taxNumber String?
  email     String?
  filePath  String?
  issuedAt  DateTime?
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("invoices")
}

model Client {
  id             String                @id @default(cuid())
  userId         String
  clientType     ClientType            @default(INDIVIDUAL)
  name           String
  gender         String?
  age            Int?
  profession     String?
  phone          String?
  email          String?
  address        String?
  idCardNumber   String?
  company        String?
  creditCode     String?
  legalRep       String?
  source         ClientSource?
  tags           String[]              @default([])
  status         ClientStatus          @default(ACTIVE)
  notes          String?
  metadata       Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  deletedAt      DateTime?
  cases          Case[]
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  communications CommunicationRecord[]
  followUpTasks  FollowUpTask[]

  @@index([userId])
  @@index([clientType])
  @@index([status])
  @@index([source])
  @@map("clients")
}

model CommunicationRecord {
  id               String            @id @default(cuid())
  clientId         String
  userId           String
  type             CommunicationType @default(PHONE)
  summary          String
  content          String?
  nextFollowUpDate DateTime?
  isImportant      Boolean           @default(false)
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  followUpTasks    FollowUpTask[]

  @@index([clientId])
  @@index([userId])
  @@index([type])
  @@index([nextFollowUpDate])
  @@index([createdAt])
  @@map("communication_records")
}

model FollowUpTask {
  id               String               @id @default(cuid())
  clientId         String
  communicationId  String
  userId           String
  type             CommunicationType      @default(PHONE)
  summary          String
  dueDate          DateTime
  priority         FollowUpTaskPriority @default(MEDIUM)
  status           FollowUpTaskStatus   @default(PENDING)
  completedAt      DateTime?
  notes            String?
  metadata         Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  client           Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  communication    CommunicationRecord  @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([communicationId])
  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@map("follow_up_tasks")
}

model Reminder {
  id                String               @id @default(cuid())
  userId            String
  type              ReminderType
  title             String
  message           String?              @db.Text
  reminderTime      DateTime
  channels         String[]             @default([])
  status           ReminderStatus        @default(PENDING)
  relatedType       String?
  relatedId         String?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([reminderTime])
  @@index([status])
  @@map("reminders")
}

