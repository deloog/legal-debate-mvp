// 知识图谱版本控制 - 快照模型
model KnowledgeGraphSnapshot {
  id              String     @id @default(cuid())
  snapshotDate    DateTime   @unique
  version         String     // 'DAILY' | 'WEEKLY' | 'MONTHLY' | 'MANUAL'
  versionLabel    String     // 版本标签，如 'v2026.02.25'
  
  // 快照统计
  totalArticles   Int        @default(0)
  totalRelations  Int        @default(0)
  verifiedRelations Int      @default(0)
  pendingRelations Int       @default(0)
  averageConfidence Float    @default(0)
  
  // 完整快照数据（可选，用于完整恢复）
  snapshotData    Json?      // { nodes: [], edges: [] }
  
  // 变更记录（与上一版本的差异）
  changes         Json?      // [{ type, entityType, entityId, description }]
  
  // 快照状态
  status          String     @default("COMPLETED")
  
  // 描述信息
  description     String?
  
  // 创建者
  createdBy       String?
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([snapshotDate])
  @@index([version])
  @@index([status])
  @@map("knowledge_graph_snapshots")
}

// ============================================
// 人工复核工作流模型
// ============================================

// 审核员等级枚举
enum ReviewerLevel {
  JUNIOR
  SENIOR
  EXPERT
}

// AI输出审核状态
enum AIOutputReviewStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  REVISION_REQUIRED
}

// AI输出类型
enum AIOutputType {
  LEGAL_REFERENCE
  ARGUMENT
  DOCUMENT
  CONSULTATION
  CONTRACT_CLAUSE
  RISK_ASSESSMENT
  OTHER
}

// 审核员模型
model Reviewer {
  id                String         @id @default(cuid())
  userId            String         @unique
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 审核资质
  reviewerLevel     ReviewerLevel  @default(JUNIOR)
  specialty         String[]       // 专业领域，如 ['合同法', '知识产权', '劳动法']

  // 审核统计
  totalReviews      Int            @default(0)
  approvedCount     Int            @default(0)
  rejectedCount    Int            @default(0)
  revisionCount    Int            @default(0)
  averageReviewTime Float?         // 平均审核时间（秒）

  // 质量评估
  accuracyRate      Float?         // 准确率（后续验证通过的占比）

  // 审核能力
  maxConcurrentReviews Int        @default(10)  // 最大并发审核数
  isActive         Boolean         @default(true)

  // 审核历史
  reviews          AIOutputReview[]

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([userId])
  @@index([reviewerLevel])
  @@index([isActive])
  @@map("reviewers")
}

// AI输出复核模型
model AIOutputReview {
  id                  String              @id @default(cuid())

  // 输出信息
  outputType          AIOutputType
  outputId            String?             // 关联的AI输出ID
  content             String              // AI生成的内容
  aiProvider          String?             // AI服务提供商
  aiModel             String?             // AI模型名称

  // 上下文信息（可选，关联到具体业务）
  caseId              String?
  documentId          String?
  consultationId      String?

  // 审核状态
  status              AIOutputReviewStatus @default(PENDING)

  // 优先级
  priority            Int                 @default(0)  // 数值越大优先级越高

  // 审核人
  reviewerId          String?
  reviewer            Reviewer?           @relation(fields: [reviewerId], references: [id])

  // 审核结果
  verifiedBy          String?              // 审核人ID（冗余存储）
  verifiedByUser      User?                @relation("VerifiedByUser", fields: [verifiedBy], references: [id])
  verifiedAt          DateTime?           // 审核时间
  verifiedComment     String?              // 审核意见

  // 强制溯源验证
  sourceValidated     Boolean              @default(false)  // 是否通过权威数据库验证
  sourceUrl           String?              // 权威来源链接
  validationError     String?              // 验证失败原因

  // 置信度分数
  confidenceScore     Float?               // AI输出的置信度

  // 审核历史记录
  reviewHistory       Json?                // [{ action, reviewerId, comment, timestamp }]

  // 统计信息
  reviewDuration      Int?                 // 审核耗时（秒）

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([outputType])
  @@index([outputId])
  @@index([status])
  @@index([priority])
  @@index([reviewerId])
  @@index([caseId])
  @@index([createdAt])
  @@index([verifiedBy])
  @@map("ai_output_reviews")
}

// ============================================
// 合同履约监控模型
// ============================================

// 履约节点状态
enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

// 异常类型
enum AnomalyType {
  EARLY_PAYMENT    // 超进度付款
  LATE_PAYMENT     // 延迟付款
  UNVERIFIED_PAYMENT // 未验收结算
  EARLY_DELIVERY   // 超前交付
  LATE_DELIVERY    // 延迟交付
  QUALITY_ISSUE    // 质量问题
  OTHER            // 其他
}

// 合同履约节点模型
model ContractPerformance {
  id                String          @id @default(cuid())
  contractId        String
  contract          Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)

  // 履约节点信息
  milestone         String          // 节点名称，如"首付款"、"中期交付"、"最终验收"
  milestoneDate     DateTime        // 节点日期（计划完成日期）
  milestoneStatus   MilestoneStatus @default(PENDING)
  description       String?         // 节点描述
  milestoneType     String?         // 节点类型：'payment' | 'delivery' | 'milestone' | 'deadline'

  // 实际履行情况
  actualDate        DateTime?       // 实际完成日期
  actualAmount      Decimal?        @db.Decimal(15, 2) // 实际金额
  variance          Decimal?        @db.Decimal(15, 2) // 差异（约定-实际）
  varianceReason    String?         // 差异原因

  // 异常检测
  isAnomalous       Boolean          @default(false)
  anomalyType       AnomalyType?     // 异常类型
  anomalyDescription String?         // 异常描述
  recommendedAction String?         // 推荐处理措施

  // 提醒设置
  reminderEnabled   Boolean          @default(true)
  reminderDays      Int[]            @default([7, 3, 1]) // 提前提醒天数
  reminderSent      Boolean          @default(false)
  reminderCount     Int              @default(0)
  lastReminderAt    DateTime?        // 最后一次提醒时间

  // 责任人信息
  responsibleParty  String?         // 责任人
  responsibleRole   String?         // 责任人角色

  // 关联案件（可选）
  caseId            String?

  // 备注
  notes             String?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([contractId])
  @@index([milestoneDate])
  @@index([milestoneStatus])
  @@index([isAnomalous])
  @@index([caseId])
  @@index([reminderSent])
  @@map("contract_performances")
}

// 提醒配置模型
model ReminderConfig {
  id                String          @id @default(cuid())

  // 关联企业
  enterpriseId      String?
  enterprise        EnterpriseAccount? @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  // 关联用户（个人提醒配置）
  userId            String?
  user              User?           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 提醒类型
  reminderType      String          // 'CONTRACT_MILESTONE' | 'PAYMENT_DUE' | etc.

  // 提醒设置
  enabled           Boolean          @default(true)
  channels          String[]        @default(["IN_APP"]) // 通知渠道：IN_APP, EMAIL, SMS, PUSH
  advanceDays       Int[]           @default([7, 3, 1]) // 提前提醒天数
  timeOfDay        String?         // 提醒时间（HH:mm格式），默认09:00

  // 高级设置
  isRecurring       Boolean          @default(false)
  recurringPattern  String?          // 重复模式：'DAILY' | 'WEEKLY' | 'MONTHLY'

  // 状态
  isActive          Boolean          @default(true)

  // 统计
  totalRemindersSent Int             @default(0)
  lastSentAt        DateTime?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([enterpriseId, reminderType])
  @@unique([userId, reminderType])
  @@index([enterpriseId])
  @@index([userId])
  @@index([reminderType])
  @@index([enabled])
  @@map("reminder_configs")
}

// 集成状态枚举
enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  PENDING
  SUSPENDED
}

// 同步事件类型枚举
enum IntegrationSyncEvent {
  CONTRACT_CREATED
  CONTRACT_UPDATED
  CONTRACT_STATUS_CHANGED
  PAYMENT_RECEIVED
  PAYMENT_OVERDUE
  MILESTONE_COMPLETED
  MILESTONE_OVERDUE
  ANOMALY_DETECTED
  RISK_ALERT
  COMPLIANCE_CHECK
  CUSTOM
}

// 认证类型枚举
enum IntegrationAuthType {
  API_KEY
  OAUTH2
  BASIC_AUTH
  BEARER_TOKEN
}

// 业务系统类型枚举
enum BusinessSystemType {
  ERP
  CRM
  FINANCE
  PROJECT_MANAGEMENT
  HR
  INVENTORY
  CUSTOM
}

// 业务系统集成模型
model BusinessSystemIntegration {
  id                String              @id @default(cuid())

  // 关联企业
  enterpriseId      String
  enterprise        EnterpriseAccount   @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  // 系统信息
  systemType        BusinessSystemType
  systemName        String
  systemUrl         String

  // 认证信息
  authType          IntegrationAuthType
  authToken         String?             // 加密存储
  authTokenEncrypted Boolean             @default(false)
  apiKey            String?             // 加密存储
  apiKeyEncrypted   Boolean             @default(false)
  refreshToken      String?
  tokenExpiresAt    DateTime?

  // 同步配置
  syncConfig        Json                // 同步规则配置
  syncEnabled       Boolean             @default(true)
  syncInterval      Int                 @default(3600) // 同步间隔（秒），默认1小时

  // Webhook 配置
  webhookUrl        String?
  webhookSecret     String?             // 用于签名验证
  webhookEnabled    Boolean             @default(false)
  webhookEvents     String[]            @default([]) // 订阅的事件类型

  // 状态
  status            IntegrationStatus   @default(PENDING)
  lastSyncAt        DateTime?
  lastSyncStatus   String?
  lastSyncError    String?

  // 连接测试
  connectionTestedAt DateTime?
  connectionStatus  String?

  // 统计
  totalSyncs       Int                 @default(0)
  successSyncs     Int                 @default(0)
  failedSyncs      Int                 @default(0)

  // 备注
  description       String?
  metadata          Json?

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // 关联
  syncLogs          IntegrationSyncLog[]

  // 索引
  @@index([enterpriseId])
  @@index([systemType])
  @@index([status])
  @@index([lastSyncAt])
  @@map("business_system_integrations")
}

// 集成同步日志模型
model IntegrationSyncLog {
  id                String              @id @default(cuid())

  // 关联集成
  integrationId     String
  integration       BusinessSystemIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  // 同步信息
  syncType          String              // 'manual' | 'scheduled' | 'webhook'
  eventType         IntegrationSyncEvent?
  direction         String              // 'inbound' | 'outbound'

  // 状态
  status            String              // 'pending' | 'running' | 'completed' | 'failed'
  startedAt         DateTime            @default(now())
  completedAt       DateTime?

  // 数据统计
  recordsProcessed  Int                 @default(0)
  recordsCreated    Int                 @default(0)
  recordsUpdated    Int                 @default(0)
  recordsDeleted    Int                 @default(0)

  // 错误信息
  errorMessage      String?
  errorDetails      Json?

  // 请求/响应
  requestData       Json?
  responseData      Json?

  // 执行时长（毫秒）
  duration          Int?

  createdAt         DateTime            @default(now())

  // 索引
  @@index([integrationId])
  @@index([syncType])
  @@index([status])
  @@index([startedAt])
  @@index([eventType])
  @@map("integration_sync_logs")
}

// ========== 企业风险画像系统相关枚举 ==========

// 合规规则类型
enum ComplianceRuleType {
  REGULATORY  // 监管规则
  INDUSTRY    // 行业规则
  INTERNAL    // 内部制度
}

// 合规规则来源
enum ComplianceRuleSource {
  NPC           // 全国人大
  STATE_COUNCIL // 国务院
  MINISTRY      // 部委
  INDUSTRY_ASSOCIATION // 行业协会
  INTERNAL      // 企业内部
}

// 合规检查结果
enum ComplianceCheckResult {
  COMPLIANT        // 符合
  NON_COMPLIANT    // 不符合
  PARTIAL_COMPLIANT // 部分符合
}

// 合规整改状态
enum RemediationStatus {
  PENDING      // 待整改
  IN_PROGRESS  // 整改中
  COMPLETED    // 已完成
  OVERDUE      // 已逾期
}

// 报表类型
enum ExecutiveReportType {
  RISK_OVERVIEW      // 风险概览
  COMPLIANCE_STATUS  // 合规状态
  LEGAL_EFFICENCY    // 法务效率
  CUSTOM             // 自定义
}

// ========== 企业风险画像系统相关模型 ==========

// 合规规则模型
model ComplianceRule {
  id               String             @id @default(cuid())

  // 基本信息
  ruleCode         String             @unique // 规则编号
  ruleName         String
  ruleType         ComplianceRuleType

  // 规则内容
  source           ComplianceRuleSource
  sourceUrl        String?
  description      String?
  effectiveDate    DateTime
  expiryDate       DateTime?

  // 规则映射
  businessProcesses String[]          // 关联的业务流程
  controlPoints    String[]           // 控制点
  checklistItems   Json[]             // 检查清单项

  // 状态
  status           String             @default("active") // 'active' | 'amended' | 'repealed'
  version          String             @default("1.0")
  lastUpdated      DateTime           @default(now())

  // 关联
  complianceChecks EnterpriseComplianceCheck[]
  sourceRelations  ComplianceRuleRelation[] @relation("SourceRuleRelations")
  targetRelations  ComplianceRuleRelation[] @relation("TargetRuleRelations")

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([ruleType])
  @@index([source])
  @@index([status])
  @@index([effectiveDate])
  @@map("compliance_rules")
}

// 法规关联关系模型
model ComplianceRuleRelation {
  id              String                    @id @default(cuid())

  // 关联的规则
  sourceRuleId    String
  targetRuleId    String
  sourceRule      ComplianceRule            @relation("SourceRuleRelations", fields: [sourceRuleId], references: [id], onDelete: Cascade)
  targetRule      ComplianceRule            @relation("TargetRuleRelations", fields: [targetRuleId], references: [id], onDelete: Cascade)

  // 关系类型
  relationType    ComplianceRuleRelationType // 'SUPERSEDES' | 'AMENDS' | 'REFERENCES' | 'CONFLICTS' | 'COMPLEMENTS' | 'RELATED'

  // 关系属性
  strength        Float                     @default(1.0) // 关系强度 0-1
  confidence      Float                     @default(1.0) // 置信度 0-1
  description     String?

  // 审核状态
  status          String                    @default("pending") // 'pending' | 'verified' | 'rejected'
  verifiedBy      String?
  verifiedAt      DateTime?

  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([sourceRuleId, targetRuleId, relationType])
  @@index([sourceRuleId])
  @@index([targetRuleId])
  @@index([relationType])
  @@index([status])
  @@map("compliance_rule_relations")
}

// 法规关联关系类型枚举
enum ComplianceRuleRelationType {
  SUPERSEDES    // 废止 - 新法规废止旧法规
  AMENDS        // 修订 - 新法规修订旧法规
  REFERENCES   // 引用 - 引用其他法规
  CONFLICTS    // 冲突 - 与其他法规冲突
  COMPLEMENTS   // 补充 - 补充其他法规
  RELATED      // 相关 - 与其他法规相关
}

// 企业合规检查记录模型
model EnterpriseComplianceCheck {
  id               String                 @id @default(cuid())

  // 关联
  enterpriseId     String
  enterprise       EnterpriseAccount      @relation(fields: [enterpriseId], references: [id])
  ruleId           String
  rule             ComplianceRule          @relation(fields: [ruleId], references: [id])

  // 检查结果
  checkDate        DateTime
  checkResult      ComplianceCheckResult
  checklistResults Json[]                 // 检查清单结果

  // 不符合项
  nonCompliances  Json[]                  // 具体不符合项
  remediationPlan String?                 // 整改计划
  remediationDeadline DateTime?           // 整改期限
  remediationStatus String                @default("pending") // 'pending' | 'in_progress' | 'completed' | 'overdue'

  // 审核人
  reviewerId       String?
  reviewerNotes    String?

  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([enterpriseId])
  @@index([ruleId])
  @@index([checkResult])
  @@index([checkDate])
  @@index([remediationStatus])
  @@map("enterprise_compliance_checks")
}

// 管理层报表模型
model ExecutiveReport {
  id               String             @id @default(cuid())

  // 关联企业
  enterpriseId     String
  enterprise       EnterpriseAccount  @relation(fields: [enterpriseId], references: [id])

  // 报表信息
  reportType       ExecutiveReportType

  // 报表内容
  title            String
  summary           String?
  metrics          Json               // 关键指标
  charts           Json[]             // 图表数据
  insights         String[]           // 洞察和建议

  // 生成信息
  generatedBy      String             @default("ai") // 'ai' | 'user'
  generatedAt      DateTime           @default(now())
  periodStart      DateTime
  periodEnd        DateTime

  // 分发
  recipients       String[]           // 收件人列表
  viewedCount      Int                 @default(0)
  downloadedCount  Int                 @default(0)

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([enterpriseId])
  @@index([reportType])
  @@index([generatedAt])
  @@map("executive_reports")
}

