generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                   @id @default(cuid())
  email                     String                   @unique
  username                  String?
  name                      String?
  role                      UserRole                 @default(USER)
  permissions               Json?
  organizationId            String?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  deletedAt                 DateTime?
  address                   String?
  avatar                    String?
  bio                       String?
  emailVerified             DateTime?
  lastLoginAt               DateTime?
  loginCount                Int                      @default(0)
  passwordResetExpires      DateTime?
  passwordResetToken        String?
  phone                     String?
  preferences               Json?
  status                    UserStatus               @default(ACTIVE)
  password                  String?
  accounts                  Account[]
  discussions               CaseDiscussion[]
  caseMembers               CaseTeamMember[]
  cases                     Case[]
  clients                   Client[]
  communications            CommunicationRecord[]
  debates                   Debate[]
  documentTemplates         DocumentTemplate[]
  documents                 Document[]
  enterpriseAccount         EnterpriseAccount?       @relation("UserEnterpriseAccount")
  reviewedEnterpriseReviews EnterpriseReview[]       @relation("EnterpriseReviews")
  feeRateConfigs            FeeRateConfig[]
  followUpTasks             FollowUpTask[]
  invoices                  Invoice[]
  reviewedQualifications    LawyerQualification[]    @relation("QualificationReviews")
  lawyerQualifications      LawyerQualification[]
  membershipHistoryRecords  MembershipHistory[]
  orders                    Order[]
  paymentRecords            PaymentRecord[]
  refundRecords             RefundRecord[]
  reminders                 Reminder[]
  sessions                  Session[]
  tasksAssigned             Task[]                   @relation("TasksAssigned")
  tasksCreated              Task[]                   @relation("TasksCreated")
  teamMemberships           TeamMember[]
  usageRecords              UsageRecord[]
  userMemberships           UserMembership[]
  verificationCodes         VerificationCode[]
  notifications             Notification[]
  consultations             Consultation[]
  recommendationFeedbacks   RecommendationFeedback[]
  relationFeedbacks         RelationFeedback[]
  ExportTask                ExportTask[]

  @@index([email])
  @@index([username])
  @@index([organizationId])
  @@index([status])
  @@index([lastLoginAt])
  @@index([passwordResetToken])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Case {
  id              String           @id @default(cuid())
  userId          String
  title           String
  description     String
  type            CaseType
  status          CaseStatus       @default(DRAFT)
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  amount          Decimal?
  caseNumber      String?
  cause           String?
  court           String?
  defendantName   String?
  plaintiffName   String?
  clientId        String?
  ownerType       OwnerType        @default(USER)
  sharedWithTeam  Boolean          @default(false)
  discussions     CaseDiscussion[]
  teamMembers     CaseTeamMember[]
  timelines       CaseTimeline[]
  client          Client?          @relation(fields: [clientId], references: [id])
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courtSchedules  CourtSchedule[]
  debates         Debate[]
  documents       Document[]
  evidence        Evidence[]
  legalReferences LegalReference[]
  tasks           Task[]
  witnesses       Witness[]
  contracts       Contract[]

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([plaintiffName])
  @@index([defendantName])
  @@index([cause])
  @@index([userId, status, createdAt])
  @@index([userId, type, createdAt])
  @@index([status, createdAt])
  @@index([deletedAt])
  @@index([ownerType])
  @@index([sharedWithTeam])
  @@map("cases")
}

model CaseTimeline {
  id          String                @id @default(cuid())
  caseId      String
  eventType   CaseTimelineEventType
  title       String
  description String?
  eventDate   DateTime
  metadata    Json?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  case        Case                  @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([eventType])
  @@index([eventDate])
  @@map("case_timelines")
}

model Evidence {
  id             String             @id @default(cuid())
  caseId         String
  type           EvidenceType       @default(DOCUMENT)
  name           String
  description    String?
  fileUrl        String?
  submitter      String?
  source         String?
  status         EvidenceStatus     @default(PENDING)
  relevanceScore Float?
  metadata       Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  case           Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  relations      EvidenceRelation[]

  @@index([caseId])
  @@index([type])
  @@index([status])
  @@index([relevanceScore])
  @@index([deletedAt])
  @@map("evidence")
}

model EvidenceRelation {
  id           String               @id @default(cuid())
  evidenceId   String
  relationType EvidenceRelationType
  relatedId    String
  description  String?
  createdAt    DateTime             @default(now())
  evidence     Evidence             @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@index([evidenceId])
  @@index([relationType])
  @@index([relatedId])
  @@map("evidence_relations")
}

model CourtSchedule {
  id        String              @id @default(cuid())
  caseId    String
  title     String
  type      CourtScheduleType   @default(TRIAL)
  startTime DateTime
  endTime   DateTime
  location  String?
  judge     String?
  notes     String?
  status    CourtScheduleStatus @default(SCHEDULED)
  metadata  Json?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  case      Case                @relation(fields: [caseId], references: [id], onDelete: Cascade)
  witnesses Witness[]

  @@unique([caseId, startTime])
  @@index([caseId])
  @@index([type])
  @@index([startTime])
  @@index([status])
  @@map("court_schedules")
}

model CaseDiscussion {
  id        String    @id @default(cuid())
  caseId    String
  userId    String
  content   String
  mentions  String[]  @default([])
  isPinned  Boolean   @default(false)
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  case      Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([userId])
  @@index([createdAt])
  @@index([isPinned])
  @@index([deletedAt])
  @@map("case_discussions")
}

model Document {
  id             String         @id @default(cuid())
  caseId         String
  userId         String
  filename       String
  filePath       String
  fileType       String
  fileSize       Int
  mimeType       String
  extractedData  Json?
  analysisStatus AnalysisStatus @default(PENDING)
  analysisResult Json?
  analysisError  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  case           Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([userId])
  @@index([analysisStatus])
  @@index([caseId, analysisStatus, createdAt])
  @@index([userId, analysisStatus, createdAt])
  @@index([deletedAt])
  @@map("documents")
}

model Debate {
  id           String        @id @default(cuid())
  caseId       String
  userId       String
  title        String
  status       DebateStatus  @default(DRAFT)
  currentRound Int           @default(0)
  debateConfig Json?
  summary      Json? // AI生成的辩论总结 {verdict, analysis, keyPoints, generatedAt}
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  rounds       DebateRound[]
  case         Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status, createdAt])
  @@index([caseId, status, createdAt])
  @@index([deletedAt])
  @@map("debates")
}

model DebateRound {
  id          String      @id @default(cuid())
  debateId    String
  roundNumber Int
  status      RoundStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  arguments   Argument[]
  debate      Debate      @relation(fields: [debateId], references: [id], onDelete: Cascade)

  @@unique([debateId, roundNumber])
  @@index([debateId])
  @@index([status])
  @@map("debate_rounds")
}

model Argument {
  id             String       @id @default(cuid())
  roundId        String
  side           ArgumentSide
  content        String
  type           ArgumentType @default(MAIN_POINT)
  aiProvider     String?
  generationTime Int?
  confidence     Float?
  reasoning      String? // 推理逻辑
  legalBasis     Json? // 法律依据数组 [{lawName, articleNumber, relevance, explanation}]
  logicScore     Float? // 逻辑清晰度评分
  legalScore     Float? // 法律准确性评分
  overallScore   Float? // 综合评分
  priority       String? // 律师标记优先级：'primary' | 'secondary' | null
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  round          DebateRound  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId])
  @@index([side])
  @@index([priority])
  @@map("arguments")
}

model LegalReference {
  id                  String               @id @default(cuid())
  caseId              String?
  source              String
  content             String
  lawType             String?
  articleNumber       String?
  retrievalQuery      String?
  relevanceScore      Float?
  metadata            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  amendmentHistory    Json?
  analysisResult      Json?
  analyzedAt          DateTime?
  analyzedBy          String?
  applicabilityReason String?
  applicabilityScore  Float?
  cacheExpiry         DateTime?
  cacheSource         String?
  category            String?
  effectiveDate       DateTime?
  expiryDate          DateTime?
  hitCount            Int                  @default(0)
  lastAccessed        DateTime?
  status              LegalReferenceStatus @default(VALID)
  tags                String[]
  version             String?
  case                Case?                @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([lawType])
  @@index([relevanceScore])
  @@index([applicabilityScore])
  @@index([status])
  @@index([cacheExpiry])
  @@index([hitCount])
  @@index([category])
  @@map("legal_references")
}

model LawArticle {
  id               String       @id @default(cuid())
  lawName          String
  articleNumber    String
  fullText         String
  lawType          LawType
  category         LawCategory
  subCategory      String?
  tags             String[]
  keywords         String[]
  version          String       @default("1.0")
  effectiveDate    DateTime
  expiryDate       DateTime?
  status           LawStatus    @default(VALID)
  amendmentHistory Json?
  parentId         String?
  chapterNumber    String?
  sectionNumber    String?
  level            Int          @default(0)
  issuingAuthority String
  jurisdiction     String?
  relatedArticles  String[]
  legalBasis       String?
  searchableText   String
  viewCount        Int          @default(0)
  referenceCount   Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  parent           LawArticle?  @relation("ArticleHierarchy", fields: [parentId], references: [id])
  children         LawArticle[] @relation("ArticleHierarchy")

  dataSource   String     @default("local") // 'local' | 'judiciary' | 'cail' | 'lawgpt' | 'lawstar' | 'pkulaw'
  sourceId     String? // 原始数据源ID
  importedAt   DateTime? // 导入时间
  lastSyncedAt DateTime? // 最后同步时间
  syncStatus   SyncStatus @default(SYNCED) // 同步状态

  // 知识图谱关系字段
  sourceRelations LawArticleRelation[] @relation("SourceRelations")
  targetRelations LawArticleRelation[] @relation("TargetRelations")

  // 合同关联
  contracts ContractLawArticle[]

  // 用户反馈
  recommendationFeedbacks RecommendationFeedback[]

  @@unique([lawName, articleNumber])
  @@index([lawType])
  @@index([category])
  @@index([status])
  @@index([effectiveDate])
  @@index([lawName])
  @@index([articleNumber])
  @@index([tags])
  @@index([viewCount])
  @@index([referenceCount])
  @@index([dataSource])
  @@index([lastSyncedAt])
  @@index([syncStatus])
  @@map("law_articles")
}

model AIInteraction {
  id         String   @id @default(cuid())
  type       String
  provider   String
  model      String?
  request    Json
  response   Json?
  tokensUsed Int?
  duration   Int?
  cost       Float?
  success    Boolean
  error      String?
  createdAt  DateTime @default(now())
  userId     String?

  @@index([userId])
  @@index([userId, success, createdAt])
  @@index([type])
  @@index([provider])
  @@index([success])
  @@index([createdAt])
  @@map("ai_interactions")
}

model AgentMemory {
  id               String     @id @default(cuid())
  userId           String
  caseId           String?
  debateId         String?
  memoryType       MemoryType
  agentName        String
  memoryKey        String
  memoryValue      Json
  importance       Float      @default(0.5)
  accessCount      Int        @default(0)
  lastAccessedAt   DateTime?
  expiresAt        DateTime?
  compressed       Boolean    @default(false)
  compressionRatio Float?
  metadata         Json?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([agentName, memoryKey])
  @@index([userId])
  @@index([caseId])
  @@index([debateId])
  @@index([memoryType])
  @@index([agentName])
  @@index([memoryKey])
  @@index([importance])
  @@index([accessCount])
  @@index([lastAccessedAt])
  @@index([expiresAt])
  @@map("agent_memories")
}

model VerificationResult {
  id                 String           @id @default(cuid())
  entityType         String
  entityId           String
  verificationType   VerificationType
  overallScore       Float
  factualAccuracy    Float?
  logicalConsistency Float?
  taskCompleteness   Float?
  passed             Boolean
  issues             Json?
  suggestions        Json?
  verifiedBy         String
  verificationTime   Int
  metadata           Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([entityType, entityId])
  @@index([entityType])
  @@index([entityId])
  @@index([verificationType])
  @@index([overallScore])
  @@index([passed])
  @@index([createdAt])
  @@map("verification_results")
}

model ErrorLog {
  id               String        @id @default(cuid())
  userId           String?
  caseId           String?
  errorType        ErrorType
  errorCode        String
  errorMessage     String
  stackTrace       String?
  context          Json
  attemptedAction  Json?
  recoveryAttempts Int           @default(0)
  recovered        Boolean       @default(false)
  recoveryMethod   String?
  recoveryTime     Int?
  learned          Boolean       @default(false)
  learningNotes    String?
  severity         ErrorSeverity
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId])
  @@index([caseId])
  @@index([errorType])
  @@index([errorCode])
  @@index([recovered])
  @@index([learned])
  @@index([severity])
  @@index([createdAt])
  @@map("error_logs")
}

model AgentAction {
  id             String       @id @default(cuid())
  userId         String?
  caseId         String?
  debateId       String?
  agentName      String
  actionType     ActionType
  actionName     String
  actionLayer    ActionLayer
  parameters     Json
  result         Json?
  status         ActionStatus @default(PENDING)
  executionTime  Int?
  retryCount     Int          @default(0)
  parentActionId String?
  childActions   String[]
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId])
  @@index([caseId])
  @@index([debateId])
  @@index([agentName])
  @@index([actionType])
  @@index([actionName])
  @@index([actionLayer])
  @@index([status])
  @@index([parentActionId])
  @@index([createdAt])
  @@map("agent_actions")
}

model ActionLog {
  id             String            @id @default(cuid())
  userId         String
  actionType     ActionLogType
  actionCategory ActionLogCategory
  description    String
  resourceType   String?
  resourceId     String?
  ipAddress      String?
  userAgent      String?
  requestMethod  String?
  requestPath    String?
  requestParams  Json?
  responseStatus Int?
  executionTime  Int?
  metadata       Json?
  createdAt      DateTime          @default(now())

  @@index([userId])
  @@index([actionType])
  @@index([actionCategory])
  @@index([resourceType])
  @@index([createdAt])
  @@map("action_logs")
}

model LawyerQualification {
  id               String              @id @default(cuid())
  userId           String
  licenseNumber    String              @unique
  fullName         String
  idCardNumber     String
  lawFirm          String
  licensePhoto     String?
  status           QualificationStatus @default(PENDING)
  submittedAt      DateTime            @default(now())
  reviewedAt       DateTime?
  reviewerId       String?
  reviewNotes      String?
  verificationData Json?
  metadata         Json?
  reviewer         User?               @relation("QualificationReviews", fields: [reviewerId], references: [id])
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
  @@map("lawyer_qualifications")
}

model VerificationCode {
  id        String               @id @default(cuid())
  userId    String
  code      String
  type      VerificationCodeType @default(PASSWORD_RESET)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime             @default(now())
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([code])
  @@index([expiresAt])
  @@map("verification_codes")
}

model EnterpriseAccount {
  id               String             @id @default(cuid())
  userId           String             @unique
  enterpriseName   String
  creditCode       String             @unique
  legalPerson      String
  industryType     String
  businessLicense  String?
  status           EnterpriseStatus   @default(PENDING)
  submittedAt      DateTime           @default(now())
  reviewedAt       DateTime?
  reviewerId       String?
  reviewNotes      String?
  verificationData Json?
  expiresAt        DateTime?
  metadata         Json?
  user             User               @relation("UserEnterpriseAccount", fields: [userId], references: [id], onDelete: Cascade)
  reviews          EnterpriseReview[]

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
  @@map("enterprise_accounts")
}

model EnterpriseReview {
  id           String                 @id @default(cuid())
  enterpriseId String
  reviewerId   String
  reviewAction EnterpriseReviewAction
  reviewNotes  String?
  reviewData   Json?
  createdAt    DateTime               @default(now())
  enterprise   EnterpriseAccount      @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  reviewer     User                   @relation("EnterpriseReviews", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([enterpriseId])
  @@index([reviewerId])
  @@map("enterprise_reviews")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isDefault   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  resource    String
  action      String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@index([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model SystemConfig {
  id              String     @id @default(cuid())
  key             String     @unique
  value           Json
  type            ConfigType
  category        String
  description     String?
  isPublic        Boolean    @default(false)
  isRequired      Boolean    @default(false)
  defaultValue    Json?
  validationRules Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([category])
  @@index([type])
  @@index([isPublic])
  @@map("system_configs")
}

model Report {
  id            String       @id @default(cuid())
  type          ReportType
  periodStart   DateTime
  periodEnd     DateTime
  status        ReportStatus @default(PENDING)
  filePath      String?
  fileSize      Int?
  format        ReportFormat @default(HTML)
  generatedBy   String?
  generatedAt   DateTime?
  downloadCount Int          @default(0)
  metadata      Json?
  content       Json?
  error         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([type])
  @@index([status])
  @@index([periodStart])
  @@index([periodEnd])
  @@index([generatedBy])
  @@index([createdAt])
  @@map("reports")
}

model Alert {
  alertId             String        @id @default(cuid())
  ruleId              String
  ruleName            String
  severity            AlertSeverity
  status              AlertStatus   @default(TRIGGERED)
  errorLogId          String
  errorType           ErrorType
  errorMessage        String
  message             String
  details             Json?
  notificationHistory Json
  acknowledgedBy      String?
  acknowledgedAt      DateTime?
  resolvedAt          DateTime?
  resolutionNotes     String?
  triggeredAt         DateTime
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([ruleId])
  @@index([severity])
  @@index([status])
  @@index([errorLogId])
  @@index([errorType])
  @@index([triggeredAt])
  @@map("alerts")
}

model MembershipTier {
  id              String             @id @default(cuid())
  name            String             @unique
  displayName     String
  description     String
  tier            MembershipTierType @unique
  price           Decimal            @db.Decimal(10, 2)
  currency        String             @default("CNY")
  billingCycle    BillingCycle
  features        String[]
  permissions     Json
  isActive        Boolean            @default(true)
  sortOrder       Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  orders          Order[]
  tierLimits      TierLimit[]
  userMemberships UserMembership[]

  @@index([tier])
  @@index([isActive])
  @@index([sortOrder])
  @@map("membership_tiers")
}

model UserMembership {
  id              String              @id @default(cuid())
  userId          String
  tierId          String
  status          MembershipStatus    @default(PENDING)
  startDate       DateTime
  endDate         DateTime
  autoRenew       Boolean             @default(false)
  cancelledAt     DateTime?
  cancelledReason String?
  pausedAt        DateTime?
  pausedReason    String?
  notes           String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  historyRecords  MembershipHistory[]
  usageRecords    UsageRecord[]
  tier            MembershipTier      @relation(fields: [tierId], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tierId, startDate])
  @@index([userId])
  @@index([tierId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([userId, status, endDate])
  @@map("user_memberships")
}

model UsageRecord {
  id           String         @id @default(cuid())
  userId       String
