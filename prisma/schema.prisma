generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String     @id @default(cuid())
  email                String     @unique
  username             String?
  name                 String?
  password             String?
  role                 UserRole   @default(USER)
  permissions          Json?
  organizationId       String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  deletedAt            DateTime?
  address              String?
  avatar               String?
  bio                  String?
  emailVerified        DateTime?
  lastLoginAt          DateTime?
  loginCount           Int        @default(0)
  passwordResetExpires DateTime?
  passwordResetToken   String?
  phone                String?
  preferences          Json?
  status               UserStatus @default(ACTIVE)
  accounts             Account[]
  cases                Case[]
  debates              Debate[]
  documents            Document[]
  sessions             Session[]
  lawyerQualifications LawyerQualification[]
  reviewedQualifications LawyerQualification[] @relation("QualificationReviews")
  verificationCodes    VerificationCode[]

  @@index([email])
  @@index([username])
  @@index([organizationId])
  @@index([status])
  @@index([lastLoginAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Case {
  id              String           @id @default(cuid())
  userId          String
  title           String
  description     String
  type            CaseType
  status          CaseStatus       @default(DRAFT)
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  amount          Decimal?
  caseNumber      String?
  cause           String?
  court           String?
  defendantName   String?
  plaintiffName   String?
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  debates         Debate[]
  documents       Document[]
  legalReferences LegalReference[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([plaintiffName])
  @@index([defendantName])
  @@index([cause])
  @@map("cases")
}

model Document {
  id             String         @id @default(cuid())
  caseId         String
  userId         String
  filename       String
  filePath       String
  fileType       String
  fileSize       Int
  mimeType       String
  extractedData  Json?
  analysisStatus AnalysisStatus @default(PENDING)
  analysisResult Json?
  analysisError  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  case           Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([userId])
  @@index([analysisStatus])
  @@map("documents")
}

model Debate {
  id           String        @id @default(cuid())
  caseId       String
  userId       String
  title        String
  status       DebateStatus  @default(DRAFT)
  currentRound Int           @default(0)
  debateConfig Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  rounds       DebateRound[]
  case         Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("debates")
}

model DebateRound {
  id          String      @id @default(cuid())
  debateId    String
  roundNumber Int
  status      RoundStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  arguments   Argument[]
  debate      Debate      @relation(fields: [debateId], references: [id], onDelete: Cascade)

  @@unique([debateId, roundNumber])
  @@index([debateId])
  @@index([status])
  @@map("debate_rounds")
}

model Argument {
  id             String       @id @default(cuid())
  roundId        String
  side           ArgumentSide
  content        String
  type           ArgumentType @default(MAIN_POINT)
  aiProvider     String?
  generationTime Int?
  confidence     Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  round          DebateRound  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId])
  @@index([side])
  @@map("arguments")
}

model LegalReference {
  id                  String               @id @default(cuid())
  caseId              String?
  source              String
  content             String
  lawType             String?
  articleNumber       String?
  retrievalQuery      String?
  relevanceScore      Float?
  metadata            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  amendmentHistory    Json?
  analysisResult      Json?
  analyzedAt          DateTime?
  analyzedBy          String?
  applicabilityReason String?
  applicabilityScore  Float?
  cacheExpiry         DateTime?
  cacheSource         String?
  category            String?
  effectiveDate       DateTime?
  expiryDate          DateTime?
  hitCount            Int                  @default(0)
  lastAccessed        DateTime?
  status              LegalReferenceStatus @default(VALID)
  tags                String[]
  version             String?
  case                Case?                @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([lawType])
  @@index([relevanceScore])
  @@index([applicabilityScore])
  @@index([status])
  @@index([cacheExpiry])
  @@index([hitCount])
  @@index([category])
  @@map("legal_references")
}

model LawArticle {
  id                String              @id @default(cuid())

  // === 基础信息 ===
  lawName           String
  articleNumber     String
  fullText          String              @db.Text

  // === 分类系统 ===
  lawType           LawType
  category          LawCategory
  subCategory       String?
  tags              String[]
  keywords          String[]

  // === 版本管理 ===
  version           String              @default("1.0")
  effectiveDate     DateTime
  expiryDate        DateTime?
  status            LawStatus           @default(VALID)
  amendmentHistory  Json?

  // === 层级关系 ===
  parentId          String?
  chapterNumber     String?
  sectionNumber     String?
  level             Int                 @default(0)

  // === 元数据 ===
  issuingAuthority  String
  jurisdiction      String?
  relatedArticles   String[]
  legalBasis        String?

  // === 检索和统计 ===
  searchableText    String              @db.Text
  viewCount         Int                 @default(0)
  referenceCount    Int                 @default(0)

  // === 时间戳 ===
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // === 关联关系 ===
  parent            LawArticle?         @relation("ArticleHierarchy", fields: [parentId], references: [id])
  children          LawArticle[]        @relation("ArticleHierarchy")

  @@unique([lawName, articleNumber])
  @@index([lawType])
  @@index([category])
  @@index([status])
  @@index([effectiveDate])
  @@index([lawName])
  @@index([articleNumber])
  @@index([tags])
  @@index([viewCount])
  @@index([referenceCount])
  @@map("law_articles")
}

model AIInteraction {
  id         String   @id @default(cuid())
  type       String
  provider   String
  model      String?
  request    Json
  response   Json?
  tokensUsed Int?
  duration   Int?
  cost       Float?
  success    Boolean
  error      String?
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([provider])
  @@index([success])
  @@index([createdAt])
  @@map("ai_interactions")
}

// === v3.0 Manus增强表 ===

// 7. Agent记忆管理模块 - 三层记忆架构
model AgentMemory {
  id               String     @id @default(cuid())
  userId           String
  caseId           String?
  debateId         String?
  memoryType       MemoryType
  agentName        String
  memoryKey        String
  memoryValue      Json
  importance       Float      @default(0.5)
  accessCount      Int        @default(0)
  lastAccessedAt   DateTime?
  expiresAt        DateTime?
  compressed       Boolean    @default(false)
  compressionRatio Float?
  metadata         Json?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([agentName, memoryKey])
  @@index([userId])
  @@index([caseId])
  @@index([debateId])
  @@index([memoryType])
  @@index([agentName])
  @@index([memoryKey])
  @@index([importance])
  @@index([accessCount])
  @@index([lastAccessedAt])
  @@index([expiresAt])
  @@map("agent_memories")
}

// 8. 验证层模块 - 三重验证机制
model VerificationResult {
  id                 String           @id @default(cuid())
  entityType         String
  entityId           String
  verificationType   VerificationType
  overallScore       Float
  factualAccuracy    Float?
  logicalConsistency Float?
  taskCompleteness   Float?
  passed             Boolean
  issues             Json?
  suggestions        Json?
  verifiedBy         String
  verificationTime   Int
  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([entityType, entityId])
  @@index([entityType])
  @@index([entityId])
  @@index([verificationType])
  @@index([overallScore])
  @@index([passed])
  @@index([createdAt])
  @@map("verification_results")
}

// 9. 错误学习模块 - 错误学习机制
model ErrorLog {
  id               String       @id @default(cuid())
  userId           String?
  caseId           String?
  errorType        ErrorType
  errorCode        String
  errorMessage     String       @db.Text
  stackTrace       String?      @db.Text
  context          Json
  attemptedAction  Json?
  recoveryAttempts Int          @default(0)
  recovered        Boolean      @default(false)
  recoveryMethod   String?
  recoveryTime     Int?
  learned          Boolean      @default(false)
  learningNotes    String?      @db.Text
  severity         ErrorSeverity
  metadata         Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([userId])
  @@index([caseId])
  @@index([errorType])
  @@index([errorCode])
  @@index([recovered])
  @@index([learned])
  @@index([severity])
  @@index([createdAt])
  @@map("error_logs")
}

// 10. Agent行动空间模块 - 行动空间管理
model AgentAction {
  id              String       @id @default(cuid())
  userId          String?
  caseId          String?
  debateId        String?
  agentName       String
  actionType      ActionType
  actionName      String
  actionLayer     ActionLayer
  parameters      Json
  result          Json?
  status          ActionStatus @default(PENDING)
  executionTime   Int?
  retryCount      Int          @default(0)
  parentActionId  String?
  childActions    String[]
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
  @@index([caseId])
  @@index([debateId])
  @@index([agentName])
  @@index([actionType])
  @@index([actionName])
  @@index([actionLayer])
  @@index([status])
  @@index([parentActionId])
  @@index([createdAt])
  @@map("agent_actions")
}

enum UserRole {
  USER
  LAWYER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  INACTIVE
}

enum CaseType {
  CIVIL
  CRIMINAL
  ADMINISTRATIVE
  COMMERCIAL
  LABOR
  INTELLECTUAL
  OTHER
}

enum CaseStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
  DELETED
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DebateStatus {
  DRAFT
  IN_PROGRESS
  PAUSED
  COMPLETED
  ARCHIVED
}

enum RoundStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum ArgumentSide {
  PLAINTIFF
  DEFENDANT
  NEUTRAL
}

enum ArgumentType {
  MAIN_POINT
  SUPPORTING
  REBUTTAL
  EVIDENCE
  LEGAL_BASIS
  CONCLUSION
}

enum LegalReferenceStatus {
  VALID
  EXPIRED
  AMENDED
  REPEALED
  DRAFT
}

enum LawType {
  CONSTITUTION
  LAW
  ADMINISTRATIVE_REGULATION
  LOCAL_REGULATION
  JUDICIAL_INTERPRETATION
  DEPARTMENTAL_RULE
  OTHER
}

enum LawCategory {
  CIVIL
  CRIMINAL
  ADMINISTRATIVE
  COMMERCIAL
  ECONOMIC
  LABOR
  INTELLECTUAL_PROPERTY
  PROCEDURE
  OTHER
}

enum LawStatus {
  DRAFT
  VALID
  AMENDED
  REPEALED
  EXPIRED
}

// === v3.0 Manus增强枚举类型 ===

enum MemoryType {
  WORKING  // 工作记忆：当前任务上下文，TTL 1小时
  HOT      // 热记忆：近期任务经验，TTL 7天
  COLD     // 冷记忆：长期知识库，永久保留
}

enum VerificationType {
  FACTUAL        // 事实准确性验证
  LOGICAL        // 逻辑一致性验证
  COMPLETENESS   // 任务完成度验证
  COMPREHENSIVE  // 综合验证（三重）
}

enum ErrorType {
  // AI服务相关错误
  AI_SERVICE_ERROR
  AI_TIMEOUT
  AI_RATE_LIMIT
  AI_QUOTA_EXCEEDED

  // 数据库相关错误
  DATABASE_ERROR
  DATABASE_CONNECTION_ERROR
  DATABASE_QUERY_ERROR
  DATABASE_CONSTRAINT_ERROR

  // 验证相关错误
  VALIDATION_ERROR
  VALIDATION_REQUIRED_FIELD
  VALIDATION_FORMAT_ERROR
  VALIDATION_BUSINESS_RULE

  // 网络相关错误
  NETWORK_ERROR
  NETWORK_TIMEOUT
  NETWORK_CONNECTION_ERROR

  // 文件相关错误
  FILE_ERROR
  FILE_NOT_FOUND
  FILE_READ_ERROR
  FILE_WRITE_ERROR

  // Agent相关错误
  AGENT_ERROR
  AGENT_TIMEOUT
  AGENT_NOT_FOUND

  // 记忆相关错误
  MEMORY_ERROR
  MEMORY_NOT_FOUND
  MEMORY_EXPIRED

  // 其他错误
  UNKNOWN_ERROR
}

enum ErrorSeverity {
  LOW      // 低：不影响核心功能
  MEDIUM   // 中：影响部分功能
  HIGH     // 高：影响核心功能
  CRITICAL // 严重：系统无法运行
}

enum ActionType {
  ANALYZE
  RETRIEVE
  GENERATE
  VERIFY
  TRANSFORM
  COMMUNICATE
  MIGRATE_WORKING_TO_HOT
  MIGRATE_HOT_TO_COLD
}

enum ActionLayer {
  CORE     // 核心原子函数层（<20个基础操作）
  UTILITY  // 实用程序层（组合操作）
  SCRIPT   // 脚本层（复杂计算）
}

enum ActionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  RETRYING
  CANCELLED
}

// === 律师资格验证模块 ===

model LawyerQualification {
  id              String                 @id @default(cuid())
  userId          String
  licenseNumber   String                 // 17位执业证号
  fullName        String                 // 律师姓名
  idCardNumber    String                 // 身份证号
  lawFirm         String                 // 执业律所
  licensePhoto    String?                // 执业证照片路径
  status          QualificationStatus    @default(PENDING)
  submittedAt     DateTime               @default(now())
  reviewedAt      DateTime?
  reviewerId      String?                // 审核管理员ID
  reviewNotes     String?
  verificationData Json?                 // 验证数据（第三方API返回）
  metadata        Json?
  
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer        User?                  @relation("QualificationReviews", fields: [reviewerId], references: [id], onDelete: SetNull)
  
  @@unique([licenseNumber])
  @@index([userId])
  @@index([status])
  @@index([submittedAt])
  @@map("lawyer_qualifications")
}

enum QualificationStatus {
  PENDING      // 待审核
  UNDER_REVIEW // 审核中
  APPROVED     // 已通过
  REJECTED     // 已拒绝
  EXPIRED      // 已过期
}

// === 验证码模块 ===

model VerificationCode {
  id        String                  @id @default(cuid())
  userId    String
  code      String                  // 6位数字验证码
  type      VerificationCodeType     @default(PASSWORD_RESET)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime                @default(now())
  
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, type])
  @@index([code])
  @@index([expiresAt])
  @@map("verification_codes")
}

enum VerificationCodeType {
  PASSWORD_RESET     // 密码重置验证码
  EMAIL_VERIFICATION // 邮箱验证码
  PHONE_VERIFICATION // 手机验证码
}
