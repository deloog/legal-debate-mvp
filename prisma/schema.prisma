model AIFeedback {
  id                    String                @id @default(cuid())
  relationId            String
  userId                String
  feedbackType          AIFeedbackType
  aiConfidenceProvided  Float?
  userConfidenceRating  Int?
  actualCorrectness     AIFeedbackCorrectness
  comment               String?
  suggestedRelationType RelationType?
  suggestedConfidence   Float?
  aiProvider            String?
  aiModel               String?
  metadata              Json?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  relation              LawArticleRelation    @relation(fields: [relationId], references: [id], onDelete: Cascade)
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([relationId])
  @@index([userId])
  @@index([feedbackType])
  @@index([actualCorrectness])
  @@index([createdAt])
  @@map("ai_feedbacks")
}

model RecommendationFeedback {
  id           String                     @id @default(cuid())
  userId       String
  lawArticleId String
  contextType  FeedbackContextType
  contextId    String?
  feedbackType RecommendationFeedbackType
  comment      String?
  metadata     Json?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  lawArticle   LawArticle                 @relation(fields: [lawArticleId], references: [id], onDelete: Cascade)
  user         User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lawArticleId])
  @@index([contextType])
  @@index([feedbackType])
  @@index([createdAt])
  @@index([userId, lawArticleId])
  @@map("recommendation_feedbacks")
}

model RelationFeedback {
  id                    String               @id @default(cuid())
  userId                String
  relationId            String
  feedbackType          RelationFeedbackType
  suggestedRelationType RelationType?
  comment               String?
  metadata              Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  relation              LawArticleRelation   @relation(fields: [relationId], references: [id], onDelete: Cascade)
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([relationId])
  @@index([feedbackType])
  @@index([createdAt])
  @@index([userId, relationId])
  @@map("relation_feedbacks")
}

model KnowledgeGraphCache {
  id             String    @id @default(cuid())
  cacheType      String
  cacheKey       String    @unique
  cacheData      Json
  hitCount       Int       @default(0)
  expiresAt      DateTime
  createdAt      DateTime  @default(now())
  lastAccessedAt DateTime?

  @@index([cacheType])
  @@index([cacheKey])
  @@index([expiresAt])
  @@index([hitCount])
  @@map("knowledge_graph_cache")
}

model ExportTask {
  id          String           @id @default(cuid())
  userId      String
  filename    String
  exportType  ExportType
  format      ExportFormat
  status      ExportTaskStatus @default(PENDING)
  filePath    String?
  fileSize    Int?             @default(0)
  progress    Int              @default(0)
  error       String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  completedAt DateTime?
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([exportType])
  @@index([createdAt])
  @@map("export_tasks")
}

model KnowledgeGraphQualityMetrics {
  id                    String   @id @default(cuid())
  metricDate            DateTime @unique
  totalRelations        Int
  verifiedRelations     Int
  userFeedbackCount     Int
  positiveFeedbackRate  Float
  totalArticles         Int
  articlesWithRelations Int
  coverageRate          Float
  expiredRelations      Int
  staleRelations        Int
  createdAt             DateTime @default(now())

  @@index([metricDate])
  @@map("knowledge_graph_quality_metrics")
}

model ContractClauseRisk {
  id                   String    @id @default(cuid())
  contractId           String
  userId               String
  clauseText           String
  clauseNumber         String?
  clauseType           String?
  relatedLawArticleIds String[]
  riskFactors          Json[]
  riskDescription      String
  conflictRelations    String[]
  obsoleteRelations    String[]
  analyzedAt           DateTime  @default(now())
  analyzedBy           String?
  aiProvider           String?
  riskLevel            RiskLevel
  contract             Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([riskLevel])
  @@index([analyzedAt])
